#!/bin/bash
# Run a command inside a new gnome-terminal window and return the stdout result.
# This is useful when running from non-interactive environments (like agy)
# where you want to prompt the user with an interactive command and capture the output.
#
# Run the test script `run-in-terminal_test.bash` every time modifying this script.

set -e
. mutil.sh

show_help() {
  cat <<EOF
Usage: $(basename "$0") [options] [--] command [args...]

Runs a command inside a gnome-terminal window, allowing interactive execution,
and outputs the command's stdout to the host stdout.

Options:
  -t, --title TITLE         Set the terminal window title.
  -g, --geometry GEOMETRY   Set the terminal window geometry (e.g., 100x25).
  -c, --capture-stdout      Capture stdout of the command and print it.
  -h, --help                Show this help message.

The command and its arguments can be placed after a '--' separator (required only
if the command or its arguments start with a hyphen).

Examples:
  # Run a pager directly (no capture)
  run-in-terminal git ch

  # Run fzf and print selection (requires capture)
  run-in-terminal -c fzf

  # Use '--' if options are passed to the target command that look like run-in-terminal options
  run-in-terminal -- fzf -h

  # Pipe list of templates to fzf with custom title, geometry, and capture
  git-show-commit-template | run-in-terminal --title "Commit Templates" --geometry 120x30 -c fzf --multi

  # Run a complex command line with pipes inside the terminal (requires bash -c)
  run-in-terminal -c bash -c "git status -s | fzf"
EOF
}

# Parse options
TEMP=$(getopt -o '+t:g:hc' --long 'title:,geometry:,help,capture-stdout' -n 'run-in-terminal' -- "$@")
if [[ $? -ne 0 ]]; then
  exit 1
fi
eval set -- "$TEMP"

title=""
geometry="140x45"
capture_stdout=0
while true; do
  case "$1" in
    '-t'|'--title')
      title="$2"
      shift 2
      continue
      ;;
    '-g'|'--geometry')
      geometry="$2"
      shift 2
      continue
      ;;
    '-c'|'--capture-stdout')
      capture_stdout=1
      shift
      continue
      ;;
    '-h'|'--help')
      show_help
      exit 0
      ;;
    '--')
      shift
      break
      ;;
    *)
      echo "Internal error!" >&2
      exit 1
      ;;
  esac
done

if [[ $# -eq 0 ]]; then
  echo "Error: No command specified to run." >&2
  show_help
  exit 1
fi

user_cmd=("$@")

# If title is not specified, default to the command name
if [[ -z "$title" ]]; then
  title="$(basename "${user_cmd[0]}")"
fi

# Create temporary files for communication
input_tmp=$(mktemp "/tmp/run_in_terminal_input.XXXXXX")
output_tmp=$(mktemp "/tmp/run_in_terminal_output.XXXXXX")

# Ensure cleanup on exit
cleanup() {
  rm -f "$input_tmp" "$output_tmp"
}
trap cleanup EXIT

# Check if we have piped input
has_stdin=0
if [[ ! -t 0 ]]; then
  has_stdin=1
  cat > "$input_tmp"
fi

# Determine command to run inside gnome-terminal
cmd=""
if (( has_stdin )); then
  if (( capture_stdout )); then
    cmd="cat $(shescape "$input_tmp") | $(shescape "${user_cmd[@]}") > $(shescape "$output_tmp")"
  else
    cmd="cat $(shescape "$input_tmp") | $(shescape "${user_cmd[@]}")"
  fi
else
  if (( capture_stdout )); then
    cmd="$(shescape "${user_cmd[@]}") > $(shescape "$output_tmp")"
  else
    cmd="$(shescape "${user_cmd[@]}")"
  fi
fi

if isx; then
  # Launch gnome-terminal in foreground, waiting for the child to exit
  gnome-terminal \
    --geometry="$geometry" \
    --hide-menubar \
    -t "*$title" \
    --wait \
    -- bash -c "$cmd"
else
  # Fallback to direct execution if no X session
  if (( has_stdin )); then
    if (( capture_stdout )); then
      cat "$input_tmp" | "${user_cmd[@]}" > "$output_tmp"
    else
      cat "$input_tmp" | "${user_cmd[@]}"
    fi
  else
    if (( capture_stdout )); then
      "${user_cmd[@]}" > "$output_tmp"
    else
      "${user_cmd[@]}"
    fi
  fi
fi

# Output result
if (( capture_stdout )) && [[ -f "$output_tmp" ]]; then
  cat "$output_tmp"
fi
