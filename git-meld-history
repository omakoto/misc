#!/bin/bash
# Interactive Git history viewer using fzf and git-meld.
# See git-meld-history.md for details on specifications, including dirty directory/workspace (CURRENT) handling.
# Make sure to run git-meld-history_test.bash after making any changes.

# Ensure we are inside a git repository
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Error: Not a git repository" >&2
  exit 1
fi

# Loop to continuously show git log with fzf
while true; do
  # Get selections from fzf in multi-select mode.
  # We use --ansi to support colors from git log --color=always.
  # We also use --no-sort to keep the chronological order of commits.
  # Any arguments passed to this script (like a branch or file path) are passed to git log.
  # If the current directory is dirty, prepend a fake commit "(CURRENT)".
  # Show git show / local diff in the top preview pane.
  fzf_opts=(
    --ansi
    --multi
    --no-sort
    --preview '
      if [[ "{1}" == *"(CURRENT)"* ]]; then
        git status --short
        git diff --color=always HEAD
      else
        git show --stat -p --color=always {1}
      fi
    '
    --preview-window 'top:60%'
  )

  if [[ -n "$(git status --porcelain)" ]]; then
    selections=$( (printf "\e[33m(CURRENT)\e[m Local changes\n"; git log --oneline --color=always "$@") | fzf "${fzf_opts[@]}")
  else
    selections=$(git log --oneline --color=always "$@" | fzf "${fzf_opts[@]}")
  fi

  # Finish the script if no commits are selected (e.g. user cancelled with Esc / Ctrl-C)
  if [[ -z "$selections" ]]; then
    break
  fi

  # Parse the hashes from selections (first word of each line)
  hashes=()
  has_current=0
  while read -r line; do
    if [[ -n "$line" ]]; then
      hash=$(echo "$line" | awk '{print $1}')
      if [[ -n "$hash" ]]; then
        if [[ "$hash" == *"(CURRENT)"* ]]; then
          has_current=1
          hashes+=("(CURRENT)")
        else
          hashes+=("$hash")
        fi
      fi
    fi
  done <<< "$selections"

  num_hashes=${#hashes[@]}
  if (( num_hashes == 0 )); then
    break
  fi

  if (( num_hashes == 1 )); then
    commit="${hashes[0]}"
    if [[ "$commit" == "(CURRENT)" ]]; then
      # Solo selection of "(CURRENT)": show local change including new files
      untracked_files=()
      while IFS= read -r -d '' file; do
        untracked_files+=("$file")
      done < <(git ls-files -z --others --exclude-standard)

      if (( ${#untracked_files[@]} > 0 )); then
        git add -N -- "${untracked_files[@]}"
      fi

      git meld HEAD

      if (( ${#untracked_files[@]} > 0 )); then
        git reset HEAD -- "${untracked_files[@]}"
      fi
    else
      # If the commit has a parent, compare against parent.
      # Otherwise (e.g. root commit), compare against the empty tree.
      if git rev-parse --verify "${commit}^" >/dev/null 2>&1; then
        git meld "${commit}^..${commit}"
      else
        # 4b825dc642cb6eb9a001e5408d69288fbee4904f is the SHA-1 of the empty tree in git
        git meld "4b825dc642cb6eb9a001e5408d69288fbee4904f..${commit}"
      fi
    fi
  else
    if (( has_current )); then
      # Multi-selection containing (CURRENT): compare oldest commit to the current workspace
      historical_hashes=()
      for h in "${hashes[@]}"; do
        if [[ "$h" != "(CURRENT)" ]]; then
          historical_hashes+=("$h")
        fi
      done

      # Find oldest commit among the historical hashes using git log to sort them chronologically
      sorted_hashes=($(git log --no-walk --date-order --reverse --format="%H" "${historical_hashes[@]}"))
      if (( ${#sorted_hashes[@]} > 0 )); then
        oldest="${sorted_hashes[0]}"

        untracked_files=()
        while IFS= read -r -d '' file; do
          untracked_files+=("$file")
        done < <(git ls-files -z --others --exclude-standard)

        if (( ${#untracked_files[@]} > 0 )); then
          git add -N -- "${untracked_files[@]}"
        fi

        git meld "$oldest"

        if (( ${#untracked_files[@]} > 0 )); then
          git reset HEAD -- "${untracked_files[@]}"
        fi
      fi
    else
      # Find oldest and newest commits among the selected hashes using git log to sort them chronologically
      sorted_hashes=($(git log --no-walk --date-order --reverse --format="%H" "${hashes[@]}"))
      if (( ${#sorted_hashes[@]} > 0 )); then
        oldest="${sorted_hashes[0]}"
        newest="${sorted_hashes[${#sorted_hashes[@]}-1]}"
        git meld "${oldest}..${newest}"
      fi
    fi
  fi
done
