#!/bin/bash
# Interactive Git history viewer using fzf and git-meld.
# Accepts an optional first argument as the target git repository directory.
# See git-meld-history.md for details on specifications, including dirty directory/workspace (CURRENT) handling.
# Make sure to run git-meld-history_test.bash after making any changes.

# If the first argument is a directory, use it as the target git repository directory
if [[ "$1" != "" ]]; then
  cd "$1" || exit 1
  shift
fi

# Ensure we are inside a git repository
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Error: Not a git repository" >&2
  exit 1
fi

# Loop to continuously show git log with fzf
while true; do
  # Get selections from fzf using git-history-fzf
  header="[ESC]: Quit, Single-item [Enter]: Show diff, Two-item [Enter]: Diff between commits (inclusive), Multi-select [^S]: Squash commits"
  fzf_output=$(git-history-fzf -c -e ctrl-s -h "$header" "$@")

  # Finish the script if no key/selections are returned (e.g. user cancelled with Esc / Ctrl-C)
  if [[ -z "$fzf_output" ]]; then
    break
  fi

  # Read first line as the key pressed
  key=$(head -n 1 <<< "$fzf_output")
  # Remaining lines are the selections
  selections=$(tail -n +2 <<< "$fzf_output")

  # Finish the script if no commits are selected (e.g. user cancelled or selected nothing)
  if [[ -z "$selections" ]]; then
    break
  fi

  # Parse the hashes from selections (first word of each line)
  hashes=()
  has_current=0
  while read -r line; do
    if [[ -n "$line" ]]; then
      hash=$(echo "$line" | awk '{print $1}')
      if [[ -n "$hash" ]]; then
        if [[ "$hash" == *"(CURRENT)"* ]]; then
          has_current=1
          hashes+=("(CURRENT)")
        else
          hashes+=("$hash")
        fi
      fi
    fi
  done <<< "$selections"

  num_hashes=${#hashes[@]}
  if (( num_hashes == 0 )); then
    break
  fi

  if [[ "$key" == "ctrl-s" ]]; then
    if (( has_current )); then
      echo "Error: Cannot squash local changes (CURRENT)" >&2
      sleep 2
      continue
    fi
    if (( num_hashes < 2 )); then
      echo "Error: Please select at least 2 commits to squash" >&2
      sleep 2
      continue
    fi

    # Perform the squash!
    # Get full SHAs of the selected commits
    full_selected_hashes=()
    for h in "${hashes[@]}"; do
      full_sha=$(git rev-parse --verify "$h")
      full_selected_hashes+=("$full_sha")
    done

    # Sort selected commits chronologically (oldest first)
    sorted_hashes=($(git log --no-walk --date-order --reverse --format="%H" "${full_selected_hashes[@]}"))
    oldest="${sorted_hashes[0]}"

    # Find parent of the oldest commit
    if git rev-parse --verify "${oldest}^" >/dev/null 2>&1; then
      rebase_base="${oldest}^"
    else
      rebase_base="--root"
    fi

    # Create temporary python sequence editor script
    editor_script=$(mktemp)
    cat << 'EOF' > "$editor_script"
import sys
import os
import subprocess

def main() -> None:
    todo_file = sys.argv[1]
    squash_hashes_str = os.environ.get("SQUASH_HASHES", "")
    squash_hashes = set(squash_hashes_str.split())
    
    if not squash_hashes:
        return

    with open(todo_file, "r") as f:
        lines = f.readlines()

    new_lines = []
    squash_lines = []
    anchor_seen = False
    
    # First pass: find all subsequent selected commits to squash
    for line in lines:
        parts = line.strip().split()
        if len(parts) >= 2 and not line.startswith("#"):
            cmd = parts[0]
            sha = parts[1]
            try:
                full_sha = subprocess.check_output(
                    ["git", "rev-parse", "--verify", sha],
                    stderr=subprocess.DEVNULL,
                    text=True
                ).strip()
            except subprocess.CalledProcessError:
                full_sha = ""
                
            if full_sha in squash_hashes:
                if not anchor_seen:
                    anchor_seen = True
                else:
                    rest = line.strip()[len(cmd) + len(sha) + 1:].strip()
                    squash_lines.append(f"squash {sha} {rest}\n")

    # Second pass: write the new todo list
    anchor_seen = False
    for line in lines:
        parts = line.strip().split()
        if len(parts) >= 2 and not line.startswith("#"):
            sha = parts[1]
            try:
                full_sha = subprocess.check_output(
                    ["git", "rev-parse", "--verify", sha],
                    stderr=subprocess.DEVNULL,
                    text=True
                ).strip()
            except subprocess.CalledProcessError:
                full_sha = ""
                
            if full_sha in squash_hashes:
                if not anchor_seen:
                    anchor_seen = True
                    new_lines.append(line)
                    new_lines.extend(squash_lines)
                else:
                    pass
            else:
                new_lines.append(line)
        else:
            new_lines.append(line)

    with open(todo_file, "w") as f:
        f.writelines(new_lines)

if __name__ == "__main__":
    main()
EOF
    chmod +x "$editor_script"

    export SQUASH_HASHES="${sorted_hashes[*]}"
    if [[ "$rebase_base" == "--root" ]]; then
      GIT_SEQUENCE_EDITOR="python3 $editor_script" git rebase -i --root
    else
      GIT_SEQUENCE_EDITOR="python3 $editor_script" git rebase -i "$rebase_base"
    fi
    rebase_status=$?
    rm -f "$editor_script"

    if (( rebase_status != 0 )); then
      echo "Rebase/squash failed or paused for conflict resolution." >&2
      echo "Exiting script so you can resolve it in your terminal (using git rebase --continue/--abort)." >&2
      break
    fi

    # Continue the loop to show the updated history
    continue
  fi

  if (( num_hashes == 1 )); then
    commit="${hashes[0]}"
    if [[ "$commit" == "(CURRENT)" ]]; then
      # Solo selection of "(CURRENT)": show local change including new files
      untracked_files=()
      while IFS= read -r -d '' file; do
        untracked_files+=("$file")
      done < <(git ls-files -z --others --exclude-standard)

      if (( ${#untracked_files[@]} > 0 )); then
        git add -N -- "${untracked_files[@]}"
      fi

      git meld HEAD

      if (( ${#untracked_files[@]} > 0 )); then
        git reset HEAD -- "${untracked_files[@]}"
      fi
    else
      # If the commit has a parent, compare against parent.
      # Otherwise (e.g. root commit), compare against the empty tree.
      if git rev-parse --verify "${commit}^" >/dev/null 2>&1; then
        git meld "${commit}^..${commit}"
      else
        # 4b825dc642cb6eb9a001e5408d69288fbee4904f is the SHA-1 of the empty tree in git
        git meld "4b825dc642cb6eb9a001e5408d69288fbee4904f..${commit}"
      fi
    fi
  else
    if (( has_current )); then
      # Multi-selection containing (CURRENT): compare oldest commit to the current workspace
      historical_hashes=()
      for h in "${hashes[@]}"; do
        if [[ "$h" != "(CURRENT)" ]]; then
          historical_hashes+=("$h")
        fi
      done

      # Find oldest commit among the historical hashes using git log to sort them chronologically
      sorted_hashes=($(git log --no-walk --date-order --reverse --format="%H" "${historical_hashes[@]}"))
      if (( ${#sorted_hashes[@]} > 0 )); then
        oldest="${sorted_hashes[0]}"

        untracked_files=()
        while IFS= read -r -d '' file; do
          untracked_files+=("$file")
        done < <(git ls-files -z --others --exclude-standard)

        if (( ${#untracked_files[@]} > 0 )); then
          git add -N -- "${untracked_files[@]}"
        fi

        if git rev-parse --verify "${oldest}^" >/dev/null 2>&1; then
          git meld "${oldest}^"
        else
          git meld "4b825dc642cb6eb9a001e5408d69288fbee4904f"
        fi

        if (( ${#untracked_files[@]} > 0 )); then
          git reset HEAD -- "${untracked_files[@]}"
        fi
      fi
    else
      # Find oldest and newest commits among the selected hashes using git log to sort them chronologically
      sorted_hashes=($(git log --no-walk --date-order --reverse --format="%H" "${hashes[@]}"))
      if (( ${#sorted_hashes[@]} > 0 )); then
        oldest="${sorted_hashes[0]}"
        newest="${sorted_hashes[${#sorted_hashes[@]}-1]}"
        if git rev-parse --verify "${oldest}^" >/dev/null 2>&1; then
          git meld "${oldest}^..${newest}"
        else
          git meld "4b825dc642cb6eb9a001e5408d69288fbee4904f..${newest}"
        fi
      fi
    fi
  fi
done
