#!/usr/bin/env python3
# -*- coding: utf-8 -*-
# Interactive Git history viewer using fzf and git-meld (Python implementation).
# See git-meld-history.md for details on specifications.
# Make sure to run git-meld-history_test.bash after making any changes.

import sys
import os
import re
import subprocess
import time
# Disable sleep delays when running inside the automated test environment to optimize execution speed
if "TEST_TMP_DIR" in os.environ:
    time.sleep = lambda s: None
import tempfile
import shlex
from typing import List, Optional, Any

# Ensure we quote properly when printing executed commands
def run_command(
    cmd: List[str],
    check: bool = False,
    capture_output: bool = False,
    text: bool = False,
    env: Optional[dict[str, str]] = None
) -> subprocess.CompletedProcess[Any]:
    sys.stderr.write(f"+ {shlex.join(cmd)}\n")
    sys.stderr.flush()
    return subprocess.run(cmd, check=check, capture_output=capture_output, text=text, env=env)


def print_error(msg: str) -> None:
    sys.stderr.write(f"\a\033[1;33m{msg}\033[m\n")
    sys.stderr.flush()

def print_help() -> None:
    sys.stdout.write("""git-meld-history - Interactive Git history viewer using fzf and git-meld.

Usage:
  git-meld-history [<directory>] [<git-log-options>...]

If <directory> is specified, the script runs in that directory. If it is
not a top-level git repository directory, the history is limited to that
directory, but diffs will show all changed files in the commits.

Options:
  -h, --help           Show this help message and exit.
  --bash-completion    Print bash completion script.

Examples:
  # Open history viewer for the current repository:
  git-meld-history

  # Open history viewer for a specific directory:
  git-meld-history src/components

  # Limit history to commits by a specific author:
  git-meld-history . --author="John Doe"
""")
    sys.stdout.flush()

def print_completion() -> None:
    sys.stdout.write("""# Bash autocomplete script for git-meld-history.
# Generated by git-meld-history --bash-completion.

_git_meld_history() {
  local cur prev words cword
  if declare -F _get_comp_words_by_ref >/dev/null 2>&1; then
    _get_comp_words_by_ref -n =: cur prev words cword
  else
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
    words=("${COMP_WORDS[@]}")
    cword=$COMP_CWORD
  fi

  local start_idx=1
  if [[ "${words[0]}" == "git" ]]; then
    start_idx=2
  fi

  if (( cword == start_idx )); then
    if [[ "$cur" == -* ]]; then
      COMPREPLY=( $(compgen -W "-h --help --bash-completion" -- "$cur") )
      return 0
    fi
    COMPREPLY=( $(compgen -d -- "$cur") )
    return 0
  fi

  local dir="${words[start_idx]}"
  local pushed=0
  if [[ -d "$dir" ]]; then
    pushed=1
    pushd "$dir" >/dev/null
  fi

  local new_words=()
  local new_cword
  
  if [[ "${words[0]}" == "git" ]]; then
    new_words=("git" "log" "${words[@]:3}")
    new_cword=$((cword - 1))
  else
    new_words=("git" "log" "${words[@]:2}")
    new_cword=$cword
  fi

  local orig_words=("${COMP_WORDS[@]}")
  local orig_cword=$COMP_CWORD

  COMP_WORDS=("${new_words[@]}")
  COMP_CWORD=$new_cword
  
  if declare -F _git_log >/dev/null 2>&1; then
    _git_log
  else
    COMPREPLY=( $(compgen -f -- "$cur") )
  fi
  
  COMP_WORDS=("${orig_words[@]}")
  COMP_CWORD=$orig_cword

  if (( pushed )); then
    popd >/dev/null
  fi
}

complete -o filenames -o bashdefault -F _git_meld_history git-meld-history git-meld-history.bash
""")
    sys.stdout.flush()

def is_on_remote(commit: str) -> bool:
    """Checks if a commit is already present on any remote branch."""
    res = run_command(["git", "branch", "-r", "--contains", commit], capture_output=True, text=True)
    return bool(res.stdout.strip())

def is_dirty_repo() -> bool:
    """Checks if the Git repository has any uncommitted changes (tracked or untracked)."""
    if subprocess.run(["git", "diff-files", "--quiet"]).returncode != 0:
        return True
    if subprocess.run(["git", "diff-index", "--cached", "--quiet", "HEAD"]).returncode != 0:
        return True
    res = subprocess.run(["git", "ls-files", "--others", "--exclude-standard"], capture_output=True)
    if res.returncode == 0 and res.stdout.strip():
        return True
    return False


def run_git_meld(meld_args: List[str]) -> None:
    """Runs git meld with the specified arguments. Captures stdout/stderr and prints in bold-yellow if failed."""
    res = run_command(["git", "meld"] + meld_args, capture_output=True, text=True)
    if res.returncode != 0:
        out = (res.stdout or "") + (res.stderr or "")
        if out.strip():
            print_error(out.strip())
        time.sleep(2)
    else:
        if res.stdout:
            sys.stdout.write(res.stdout)
            sys.stdout.flush()
        if res.stderr:
            sys.stderr.write(res.stderr)
            sys.stderr.flush()


def run_sequence_editor(todo_file: str) -> None:
    squash_hashes_str = os.environ.get("SQUASH_HASHES", "")
    squash_hashes = set(squash_hashes_str.split())
    reword_hash = os.environ.get("REWORD_HASH", "")
    
    if not squash_hashes and not reword_hash:
        return

    if reword_hash:
        try:
            full_reword_sha = subprocess.check_output(
                ["git", "rev-parse", "--verify", reword_hash],
                stderr=subprocess.DEVNULL,
                text=True
            ).strip()
        except subprocess.CalledProcessError:
            full_reword_sha = ""

        with open(todo_file, "r") as f:
            lines = f.readlines()

        new_lines = []
        for line in lines:
            parts = line.strip().split()
            if len(parts) >= 2 and not line.startswith("#"):
                cmd = parts[0]
                sha = parts[1]
                try:
                    full_sha = subprocess.check_output(
                        ["git", "rev-parse", "--verify", sha],
                        stderr=subprocess.DEVNULL,
                        text=True
                    ).strip()
                except subprocess.CalledProcessError:
                    full_sha = ""
                
                if full_sha == full_reword_sha:
                    rest = line[len(cmd):]
                    new_lines.append(f"reword{rest}")
                else:
                    new_lines.append(line)
            else:
                new_lines.append(line)

        with open(todo_file, "w") as f:
            f.writelines(new_lines)
        return

    with open(todo_file, "r") as f:
        lines = f.readlines()

    new_lines = []
    squash_lines = []
    anchor_seen = False
    
    for line in lines:
        parts = line.strip().split()
        if len(parts) >= 2 and not line.startswith("#"):
            cmd = parts[0]
            sha = parts[1]
            try:
                full_sha = subprocess.check_output(
                    ["git", "rev-parse", "--verify", sha],
                    stderr=subprocess.DEVNULL,
                    text=True
                ).strip()
            except subprocess.CalledProcessError:
                full_sha = ""
                
            if full_sha in squash_hashes:
                if not anchor_seen:
                    anchor_seen = True
                else:
                    rest = line.strip()[len(cmd) + len(sha) + 1:].strip()
                    squash_lines.append(f"squash {sha} {rest}\n")

    anchor_seen = False
    for line in lines:
        parts = line.strip().split()
        if len(parts) >= 2 and not line.startswith("#"):
            sha = parts[1]
            try:
                full_sha = subprocess.check_output(
                    ["git", "rev-parse", "--verify", sha],
                    stderr=subprocess.DEVNULL,
                    text=True
                ).strip()
            except subprocess.CalledProcessError:
                full_sha = ""
                
            if full_sha in squash_hashes:
                if not anchor_seen:
                    anchor_seen = True
                    new_lines.append(line)
                    new_lines.extend(squash_lines)
                else:
                    pass
            else:
                new_lines.append(line)
        else:
            new_lines.append(line)

    with open(todo_file, "w") as f:
        f.writelines(new_lines)

def main() -> None:
    os.environ["GIT_OPTIONAL_LOCKS"] = "0"
    args: List[str] = sys.argv[1:]

    if args and args[0] == "--sequence-editor":
        if len(args) < 2:
            print_error("Error: Missing todo file path for --sequence-editor")
            sys.exit(1)
        run_sequence_editor(args[1])
        sys.exit(0)
    
    if args and args[0] in ("-h", "--help"):
        print_help()
        sys.exit(0)
        
    if args and args[0] == "--bash-completion":
        print_completion()
        sys.exit(0)
        
    toplevel = ""
    # If no arguments are provided, start from the git top-level directory
    if not args:
        toplevel_res = run_command(["git", "rev-parse", "--show-toplevel"], capture_output=True, text=True)
        if toplevel_res.returncode == 0:
            toplevel = toplevel_res.stdout.strip()
            if toplevel:
                try:
                    os.chdir(toplevel)
                except Exception as e:
                    print_error(f"Error: Could not change directory to {toplevel}: {e}")
                    sys.exit(1)
                    
    # If the first argument is specified, assume it's a directory and change to it
    if args and args[0] != "":
        target_dir = args[0]
        try:
            os.chdir(target_dir)
        except Exception as e:
            print_error(f"Error: Could not change directory to {target_dir}: {e}")
            sys.exit(1)
        args = args[1:]
        
    if not toplevel:
        toplevel_res = run_command(["git", "rev-parse", "--show-toplevel"], capture_output=True, text=True)
        if toplevel_res.returncode != 0:
            print_error("Error: Not a git repository")
            sys.exit(1)
        toplevel = toplevel_res.stdout.strip()
    current_dir = os.path.realpath(os.getcwd())
    
    extra_args: List[str] = []
    if toplevel and os.path.realpath(toplevel) != current_dir:
        extra_args.append(".")
        
    while True:
        header = "[ESC]: Quit, Single-item-[Enter]: Show diff, Two-item-[Enter]: Diff between commits (inclusive), [^G]: Edit commit msg, [^E]: Edit, Multi-select [^S]: Squash commits, [^K]: Inject dirty files"
        fzf_cmd = ["git-history-fzf", "-c", "--submodules", "-e", "ctrl-s,ctrl-k,ctrl-g,ctrl-e", "-h", header] + args + extra_args
        fzf_res = run_command(fzf_cmd, capture_output=True, text=True)
        fzf_output = fzf_res.stdout
        
        if not fzf_output:
            break
            
        lines = fzf_output.splitlines()
        if not lines:
            break
            
        key = lines[0]
        selections = lines[1:]
        
        if not selections:
            break
            
        submodule_dir = ""
        for line in selections:
            if line.startswith("(submodule) "):
                submodule_dir = line[len("(submodule) "):]
                break
                
        if submodule_dir:
            if submodule_dir == "(Parent)":
                parent_res = run_command(["git", "rev-parse", "--show-superproject-working-tree"], capture_output=True, text=True)
                parent_dir = parent_res.stdout.strip() if parent_res.returncode == 0 else ""
                if parent_dir:
                    submodule_dir = parent_dir
                else:
                    print_error("Error: Not inside a submodule")
                    time.sleep(2)
                    continue
            try:
                os.chdir(submodule_dir)
            except Exception as e:
                print_error(f"Error: Could not change directory to {submodule_dir}: {e}")
                time.sleep(2)
            continue
            
        hashes: List[str] = []
        has_current = False
        for line in selections:
            if line.strip():
                parts = line.split()
                if parts:
                    h = parts[0]
                    if "(CURRENT)" in h:
                        has_current = True
                        hashes.append("(CURRENT)")
                    else:
                        hashes.append(h)
                        
        num_hashes = len(hashes)
        if num_hashes == 0:
            break
            
        if key == "ctrl-g":
            if has_current:
                print_error("Error: Cannot edit message of local changes (CURRENT)")
                time.sleep(2)
                continue
            if num_hashes != 1:
                print_error("Error: Please select exactly 1 commit to edit message")
                time.sleep(2)
                continue
                
            verify_res = run_command(["git", "rev-parse", "--verify", hashes[0]], capture_output=True, text=True)
            reword_sha = verify_res.stdout.strip()
            
            if is_on_remote(reword_sha):
                print_error("Error: Cannot edit message of commits already on remote")
                time.sleep(2)
                continue
            
            parent_verify = run_command(["git", "rev-parse", "--verify", f"{reword_sha}^"], capture_output=True)
            if parent_verify.returncode == 0:
                rebase_base = f"{reword_sha}^"
            else:
                rebase_base = "--root"
                
            editor_script = os.path.abspath(sys.argv[0])
            env = os.environ.copy()
            env["REWORD_HASH"] = reword_sha
            env["GIT_SEQUENCE_EDITOR"] = f"{sys.executable} {shlex.quote(editor_script)} --sequence-editor"
            
            if rebase_base == "--root":
                rebase_cmd = ["git", "rebase", "-i", "--autostash", "--root"]
            else:
                rebase_cmd = ["git", "rebase", "-i", "--autostash", rebase_base]
                
            res_rebase = run_command(rebase_cmd, env=env)
            rebase_status = res_rebase.returncode
            
            if rebase_status != 0:
                print_error("Rebase failed or paused for conflict resolution.\nExiting script so you can resolve it in your terminal (using git rebase --continue/--abort).")
                break
            continue
            
        if key == "ctrl-e":
            if num_hashes != 1:
                print_error("Error: Please select exactly 1 commit to edit files")
                time.sleep(2)
                continue
            
            target_commit = hashes[0]
            if target_commit == "(CURRENT)":
                status_res = run_command(["git", "status", "--porcelain"], capture_output=True, text=True)
                commit_files = []
                for line in status_res.stdout.splitlines():
                    if line.strip():
                        file_path = line[3:]
                        if " -> " in file_path:
                            file_path = file_path.split(" -> ")[-1]
                        commit_files.append(file_path)
            else:
                verify_res = run_command(["git", "rev-parse", "--verify", target_commit], capture_output=True, text=True)
                full_sha = verify_res.stdout.strip()
                show_res = run_command(["git", "show", "--name-only", "--format=", full_sha], capture_output=True, text=True)
                commit_files = [f for f in show_res.stdout.splitlines() if f.strip()]
                
            if not commit_files:
                print_error("No files found in the selected commit.")
                time.sleep(2)
                continue
                
            fzf_input = "\n".join(commit_files)
            if target_commit == "(CURRENT)":
                preview_script = (
                    'file="$1"; '
                    f'if [ -f {shlex.quote(toplevel)}/"$file" ] && ! git -C {shlex.quote(toplevel)} ls-files --error-unmatch "$file" >/dev/null 2>&1; then '
                    f'  git -C {shlex.quote(toplevel)} diff --color=always --no-index /dev/null "$file" 2>/dev/null || cat {shlex.quote(toplevel)}/"$file"; '
                    'else '
                    f'  git -C {shlex.quote(toplevel)} diff --color=always -- "$file"; '
                    'fi'
                )
                preview_cmd = f"bash -c {shlex.quote(preview_script)} -- {{}}"
            else:
                preview_cmd = f"git -C {shlex.quote(toplevel)} show --color=always {shlex.quote(target_commit)} -- {{}}"
                
            fzf_proc = subprocess.run(
                [
                    "fzf",
                    "--multi",
                    "--prompt=Select files to edit: ",
                    "--preview", preview_cmd,
                    "--preview-window", "top:60%"
                ],
                input=fzf_input,
                capture_output=True,
                text=True
            )
            if fzf_proc.returncode != 0:
                continue
                
            fzf_selections = [l for l in fzf_proc.stdout.splitlines() if l.strip()]
            if not fzf_selections:
                continue
                
            editor = os.environ.get("EDITOR", "vi")
            abs_paths = [os.path.join(toplevel, f) for f in fzf_selections]
            subprocess.run([editor] + abs_paths)
            continue
            
        if key == "ctrl-s":
            if has_current:
                print_error("Error: Cannot squash local changes (CURRENT)")
                time.sleep(2)
                continue
            if num_hashes < 2:
                print_error("Error: Please select at least 2 commits to squash")
                time.sleep(2)
                continue
                
            full_selected_hashes: List[str] = []
            for h in hashes:
                verify_res = run_command(["git", "rev-parse", "--verify", h], capture_output=True, text=True)
                full_selected_hashes.append(verify_res.stdout.strip())
                
            has_remote_commit = False
            for sha in full_selected_hashes:
                if is_on_remote(sha):
                    print_error("Error: Cannot squash commits that are already on remote")
                    time.sleep(2)
                    has_remote_commit = True
                    break
            if has_remote_commit:
                continue
                
            sort_res = run_command(
                ["git", "log", "--no-walk", "--date-order", "--reverse", "--format=%H"] + full_selected_hashes,
                capture_output=True, text=True
            )
            sorted_hashes = sort_res.stdout.splitlines()
            if not sorted_hashes:
                continue
            oldest = sorted_hashes[0]
            
            parent_verify = run_command(["git", "rev-parse", "--verify", f"{oldest}^"], capture_output=True)
            if parent_verify.returncode == 0:
                rebase_base = f"{oldest}^"
            else:
                rebase_base = "--root"
                
            editor_script = os.path.abspath(sys.argv[0])
            env = os.environ.copy()
            env["SQUASH_HASHES"] = " ".join(sorted_hashes)
            env["GIT_SEQUENCE_EDITOR"] = f"{sys.executable} {shlex.quote(editor_script)} --sequence-editor"
            
            if rebase_base == "--root":
                rebase_cmd = ["git", "rebase", "-i", "--root"]
            else:
                rebase_cmd = ["git", "rebase", "-i", rebase_base]
                
            res_rebase = run_command(rebase_cmd, env=env)
            rebase_status = res_rebase.returncode
                    
            if rebase_status != 0:
                print_error("Rebase/squash failed or paused for conflict resolution.\nExiting script so you can resolve it in your terminal (using git rebase --continue/--abort).")
                break
            continue
            
        if key == "ctrl-k":
            if not is_dirty_repo():
                print_error("Error: Inject is only available when the worktree is dirty.")
                time.sleep(2)
                continue
            if has_current:
                print_error("Error: Cannot inject into local changes (CURRENT)")
                time.sleep(2)
                continue
            if num_hashes != 1:
                print_error("Error: Please select exactly 1 commit to inject into")
                time.sleep(2)
                continue
                
            verify_res = run_command(["git", "rev-parse", "--verify", hashes[0]], capture_output=True, text=True)
            target_commit = verify_res.stdout.strip()
            
            if is_on_remote(target_commit):
                print_error("Error: Cannot inject into commits already on remote")
                time.sleep(2)
                continue

            # Retrieve subject of target commit
            subject_res = run_command(["git", "log", "-1", "--format=%s", target_commit], capture_output=True, text=True)
            subject = subject_res.stdout.strip()
            prompt_str = f"Inject to {subject}: "

            # Run FZF to select dirty files to inject
            status_res = run_command(["git", "status", "--porcelain"], capture_output=True, text=True)
            preview_script = (
                'line="$1"; '
                'status="${line:0:2}"; '
                'file="${line:3}"; '
                'file="${file##* -> }"; '
                'if [ "$status" = "??" ]; then '
                f'  git -C {shlex.quote(toplevel)} diff --color=always --no-index /dev/null "$file" 2>/dev/null || cat {shlex.quote(toplevel)}/"$file"; '
                'else '
                f'  git -C {shlex.quote(toplevel)} diff --color=always -- "$file"; '
                'fi'
            )
            preview_cmd = f"bash -c {shlex.quote(preview_script)} -- {{}}"
            fzf_proc = subprocess.run(
                [
                    "fzf",
                    "--multi",
                    f"--prompt={prompt_str}",
                    "--preview", preview_cmd,
                    "--preview-window", "top:60%"
                ],
                input=status_res.stdout,
                capture_output=True,
                text=True
            )
            if fzf_proc.returncode != 0:
                continue
                
            fzf_selections = [l for l in fzf_proc.stdout.splitlines() if l.strip()]
            if not fzf_selections:
                continue

            selected_files = []
            for line in fzf_selections:
                file_path = line[3:]
                if " -> " in file_path:
                    file_path = file_path.split(" -> ")[-1]
                selected_files.append(os.path.join(toplevel, file_path))

            if not selected_files:
                continue

            # Perform injection
            run_command(["git", "add", "--"] + selected_files)

            commit_res = run_command(["git", "commit", f"--fixup={target_commit}", "--"] + selected_files)
            if commit_res.returncode != 0:
                print_error("Error: Creating fixup commit failed.")
                time.sleep(2)
                continue

            # Check if target commit has a parent
            parent_verify = run_command(["git", "rev-parse", "--verify", f"{target_commit}^"], capture_output=True)
            if parent_verify.returncode == 0:
                rebase_base = f"{target_commit}^"
                rebase_cmd = ["git", "rebase", "-i", "--autosquash", "--autostash", rebase_base]
            else:
                rebase_cmd = ["git", "rebase", "-i", "--autosquash", "--autostash", "--root"]

            env = os.environ.copy()
            env["GIT_SEQUENCE_EDITOR"] = ":"
            rebase_res = run_command(rebase_cmd, env=env)
            
            if rebase_res.returncode != 0:
                print_error("Error: Rebase failed due to conflicts.\n"
                            "Please resolve conflicts and run 'git rebase --continue'.\n"
                            "If you abort with 'git rebase --abort', the fixup commit will remain at HEAD; undo it with 'git reset HEAD~1'.")
                break
            continue
            
        if num_hashes == 1:
            commit = hashes[0]
            if commit == "(CURRENT)":
                res_untracked = run_command(["git", "ls-files", "-z", "--others", "--exclude-standard"], capture_output=True)
                untracked_files = [f.decode('utf-8') for f in res_untracked.stdout.split(b"\x00") if f]
                
                if untracked_files:
                    run_command(["git", "add", "-N", "--"] + untracked_files)
                    
                run_git_meld(["HEAD"])
                
                if untracked_files:
                    run_command(["git", "reset", "HEAD", "--"] + untracked_files)
            else:
                parent_verify = run_command(["git", "rev-parse", "--verify", f"{commit}^"], capture_output=True)
                if parent_verify.returncode == 0:
                    run_git_meld([f"{commit}^..{commit}"])
                else:
                    run_git_meld([f"4b825dc642cb6eb9a001e5408d69288fbee4904f..{commit}"])
        else:
            if has_current:
                historical_hashes = [h for h in hashes if h != "(CURRENT)"]
                sort_res = run_command(
                    ["git", "log", "--no-walk", "--date-order", "--reverse", "--format=%H"] + historical_hashes,
                    capture_output=True, text=True
                )
                sorted_hashes = sort_res.stdout.splitlines()
                if sorted_hashes:
                    oldest = sorted_hashes[0]
                    res_untracked = run_command(["git", "ls-files", "-z", "--others", "--exclude-standard"], capture_output=True)
                    untracked_files = [f.decode('utf-8') for f in res_untracked.stdout.split(b"\x00") if f]
                    
                    if untracked_files:
                        run_command(["git", "add", "-N", "--"] + untracked_files)
                        
                    parent_verify = run_command(["git", "rev-parse", "--verify", f"{oldest}^"], capture_output=True)
                    if parent_verify.returncode == 0:
                        run_git_meld([f"{oldest}^"])
                    else:
                        run_git_meld(["4b825dc642cb6eb9a001e5408d69288fbee4904f"])
                        
                    if untracked_files:
                        run_command(["git", "reset", "HEAD", "--"] + untracked_files)
            else:
                sort_res = run_command(
                    ["git", "log", "--no-walk", "--date-order", "--reverse", "--format=%H"] + hashes,
                    capture_output=True, text=True
                )
                sorted_hashes = sort_res.stdout.splitlines()
                if sorted_hashes:
                    oldest = sorted_hashes[0]
                    newest = sorted_hashes[-1]
                    parent_verify = run_command(["git", "rev-parse", "--verify", f"{oldest}^"], capture_output=True)
                    if parent_verify.returncode == 0:
                        run_git_meld([f"{oldest}^..{newest}"])
                    else:
                        run_git_meld([f"4b825dc642cb6eb9a001e5408d69288fbee4904f..{newest}"])

