#!/usr/bin/env python3
#
# list-files - Traverse directories and list files depth-first.
#
# Run the test suite via `python3 misc/list-files_test.py` whenever making changes.
#

import argparse
import os
import sys
from typing import List, Optional

# Directories that are hidden by default unless -a/--show-all is specified.
HIDDEN_DIRECTORIES = {
    ".git",
}

class TraversalState:
    """Tracks the state of traversal, including limits on max files printed."""
    def __init__(self, max_files: Optional[int] = None) -> None:
        self.max_files = max_files
        self.printed = 0

    @property
    def limit_reached(self) -> bool:
        return self.max_files is not None and self.printed >= self.max_files

def traverse_dir(start_dir: str, reverse: bool, state: Optional[TraversalState] = None, show_directories: bool = False, show_all: bool = False) -> bool:
    """Traverses start_dir in a depth-first manner and prints files and directories.
    
    Inside each directory, the entries are sorted alphabetically (or reverse alphabetical
    order if reverse is True).
    
    Returns:
        True if the traversal succeeded without errors, False otherwise.
    """
    if not os.path.isdir(start_dir):
        print(f"Error: '{start_dir}' is not a directory.", file=sys.stderr)
        return False

    if state is None:
        state = TraversalState()

    if show_directories:
        if state.limit_reached:
            return True
        dir_path = start_dir if start_dir.endswith('/') else (start_dir + '/')
        print(dir_path)
        state.printed += 1

    return _traverse_dir_recursive(start_dir, reverse, state, show_directories, show_all)

def _traverse_dir_recursive(current_dir: str, reverse: bool, state: TraversalState, show_directories: bool = False, show_all: bool = False) -> bool:
    """Recursive helper for depth-first traversal."""
    try:
        with os.scandir(current_dir) as it:
            entries = list(it)
    except OSError as e:
        print(f"Error reading directory '{current_dir}': {e}", file=sys.stderr)
        return False

    # Sort the entries by name alphabetically (or reverse)
    entries.sort(key=lambda x: x.name, reverse=reverse)

    success = True
    # Print only files (or symlinks to files), and recurse into directories
    for entry in entries:
        if state.limit_reached:
            break

        try:
            is_dir = entry.is_dir()
        except OSError as e:
            print(f"Error checking entry '{entry.path}': {e}", file=sys.stderr)
            success = False
            continue

        if not show_all and is_dir and entry.name in HIDDEN_DIRECTORIES:
            continue

        try:
            is_file = entry.is_file()
            is_dir_to_print = is_dir if show_directories else False
        except OSError as e:
            print(f"Error checking entry '{entry.path}': {e}", file=sys.stderr)
            success = False
            is_file = False
            is_dir_to_print = False

        if is_file or is_dir_to_print:
            path_to_print = entry.path
            if is_dir_to_print and not path_to_print.endswith('/'):
                path_to_print += '/'
            print(path_to_print)
            state.printed += 1

        try:
            # Avoid traversing symlinks to directories to prevent infinite recursion/loops
            if entry.is_dir(follow_symlinks=False):
                if state.limit_reached:
                    break
                if not _traverse_dir_recursive(entry.path, reverse, state, show_directories, show_all):
                    success = False
        except OSError as e:
            print(f"Error checking entry '{entry.path}': {e}", file=sys.stderr)
            success = False

    return success

def main() -> None:
    parser = argparse.ArgumentParser(
        description="Traverse directories and list files in a depth-first way.",
        epilog="""
Examples:
  list-files dir1
  list-files -r dir1 dir2
        """,
        formatter_class=argparse.RawDescriptionHelpFormatter
    )
    parser.add_argument(
        "-r",
        "--reverse",
        action="store_true",
        help="Sort files in reverse alphabetical order."
    )
    parser.add_argument(
        "-n",
        "--max-files",
        type=int,
        default=None,
        metavar="MAX-FILES",
        help="Limit the number of files listed."
    )
    parser.add_argument(
        "-d",
        "--show-directories",
        action="store_true",
        help="Print directories too."
    )
    parser.add_argument(
        "-a",
        "--show-all",
        action="store_true",
        help="Show hidden directories (like .git) that are hidden by default."
    )
    parser.add_argument(
        "directories",
        nargs="*",
        default=["."],
        metavar="DIR",
        help="One or more directory names to traverse. Defaults to the current directory if not specified."
    )

    args = parser.parse_args()

    if args.max_files is not None and args.max_files < 0:
        parser.error("argument -n/--max-files: must be a non-negative integer")

    overall_success = True
    state = TraversalState(args.max_files)
    for directory in args.directories:
        if state.limit_reached:
            break
        if not traverse_dir(directory, args.reverse, state, args.show_directories, args.show_all):
            overall_success = False

    if not overall_success:
        sys.exit(1)

if __name__ == "__main__":
    main()
