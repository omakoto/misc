#!/bin/bash

set -e

if [[ "${0##*/}" == "gg1" ]]; then
  tmp=$(mktemp /tmp/git-commit-history-XXXXXXXX.log)
  git-commit-history-raw > "$tmp"
  1 "$tmp"
  exit 0
fi

# When run inside Antigravity/Claude, it launches in a new gnome-terminal using run-in-terminal.
if needs-term; then
  exec term --geometry=160x45 --no-wait -- "$0" "$@"
fi

function _ggh_preview() {
  hl '^    .*' '@cyan' \
  '^[^ ].*' '@yellow' \
  '\+(?=[+\-]*\s*$)' '@green' \
  '\-(?=[+\-]*\s*$)' '@red'
}
export -f _ggh_preview

if [[ "${0##*/}" == "ggl" ]]; then
  # Original, less-based viewer.
  git-commit-history-raw | {
      if [[ -t 1 ]] ; then
          _ggh_preview | less --raw
      else
          cat
      fi
  }
  exit $?
fi

auto-term-close-on-idle

exec prowl --sort=path-desc --preview-height 70% --preview '_ggh_preview < {}' $HOME/history/commits/
