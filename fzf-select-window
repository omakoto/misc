#!/bin/bash
# fzf-select-window - Select and activate a GNOME Shell window using fzf.
#
# Run the test script to verify changes:
#   cd ~/cbin/misc && ./fzf-select-window_test.bash
#

set -e

if needs-term ; then
    exec t --no-wait -g 120x20 fzf-select-window
fi

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
. mutil.sh

# Locate dependencies, allowing overrides for testing
: "${GNOME_LIST_WINDOWS:=$SCRIPT_DIR/../gnome-list-windows}"
if [[ ! -x "$GNOME_LIST_WINDOWS" && "$GNOME_LIST_WINDOWS" == "$SCRIPT_DIR/../gnome-list-windows" ]]; then
  GNOME_LIST_WINDOWS="gnome-list-windows"
fi

: "${FZF:=fzf}"
: "${GDBUS:=gdbus}"

function print_help() {
  cat <<'EOF'
fzf-select-window - Select and activate a GNOME Shell window using fzf.

Usage:
  fzf-select-window [options]

Options:
  -h, --help  Show this help message and exit.

Examples:
  fzf-select-window
EOF
}

# Parse options using GNU getopt
TEMP=$(getopt -o 'h' --long 'help' -n 'fzf-select-window' -- "$@")
eval set -- "$TEMP"
while true; do
  case "$1" in
    -h|--help)
      print_help
      exit 0
      ;;
    --)
      shift
      break
      ;;
    *)
      echo "Internal error!" >&2
      exit 1
      ;;
  esac
done

if (( $# > 0 )); then
  echo "fzf-select-window: Unknown option or argument: $1" >&2
  print_help >&2
  exit 1
fi

list_windows_formatted() {
  local windows_json
  windows_json=$( "$GNOME_LIST_WINDOWS" --jsonl )
  if [[ $? -ne 0 || -z "$windows_json" ]]; then
    echo "Error: Failed to get window list from $GNOME_LIST_WINDOWS" >&2
    return 1
  fi

  # Parse JSON lines in a single pass using jq to speed it up and avoid subprocesses in loop
  local line id title cwd comm normalized_cwd cyan_cwd byellow_comm is_first=1
  # Read tab-separated values from jq output
  jq -r '[.id, .title, .cwd, .comm] | @tsv' <<< "$windows_json" | while IFS=$'\t' read -r id title cwd comm; do
    if (( is_first )); then
      is_first=0
      if [[ "$title" == "*fzf-select-window" ]]; then
        continue
      fi
    fi
    if [[ -z "$id" || "$id" == "null" ]]; then
      continue
    fi
    if [[ "$cwd" == "?" || -z "$cwd" || "$cwd" == "null" ]]; then
      normalized_cwd="?"
    else
      normalized_cwd=$(dir-normalize "$cwd")
    fi
    if [[ -z "$comm" || "$comm" == "null" ]]; then
      comm="?"
    fi
    cyan_cwd=$'\e[36m'"# $normalized_cwd"$'\e[0m'
    byellow_comm=$'\e[1;33m'"[$comm]"$'\e[0m'
    printf "%s\t%-30s %-40s\t%s\n" "$id" "$byellow_comm" "$title" "$cyan_cwd"
  done
}

# Clean FZF_DEFAULT_OPTS to remove --header options to avoid displaying empty lines in fzf
if [[ -n "$FZF_DEFAULT_OPTS" ]]; then
  FZF_DEFAULT_OPTS=$(echo "$FZF_DEFAULT_OPTS" | perl -pe 's/--header(?:[= ]\s*(\x27[^\x27]*\x27|"[^"]*"|\S+))//g')
  export FZF_DEFAULT_OPTS
fi

auto-term-close-on-idle

# Main execution
# Run fzf on the formatted window list
selected=$(list_windows_formatted | "$FZF" --ansi --delimiter=$'\t' --with-nth=2.. --no-multi)

if [[ -n "$selected" ]]; then
  # Extract ID (first tab-separated field)
  id=$(echo "$selected" | cut -f1)
  if [[ -n "$id" ]]; then
    # Activate the window using the Window Calls D-Bus interface
    "$GDBUS" call --session \
                 --dest org.gnome.Shell \
                 --object-path /org/gnome/Shell/Extensions/Windows \
                 --method org.gnome.Shell.Extensions.Windows.Activate \
                 "uint32 $id" >/dev/null
  fi
fi
