#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
git-meld - A Git diff tool wrapper using Meld for directory-level comparisons.

This script acts as a bridge between git diff and Meld, allowing you to
visually compare branches, commits, the staging area, or the working directory
in a directory-based Meld window. The diff tool is launched in the background.

Usage:
  git-meld [<options>] [<commit> [<commit>]] [--] [<path>...]
  git-meld [<options>] <commit>..<commit> [--] [<path>...]
  git-meld [<options>] <commit>...<commit> [--] [<path>...]

Options compatible with git-diff:
  --cached, --staged      Compare staging area (index) instead of working directory.
  -h, --help              Show this help message and exit.

Options specific to git-meld:
  --no-rename-detection   Disable rename detection mapping.

All other options (like -w, --ignore-all-space) are passed through to `git diff`
to filter the list of files compared in Meld.
"""

import sys
import os
import subprocess
import tempfile
import shutil
import tarfile
import io
import stat
import shlex
from typing import List, Tuple, Set, Dict, Optional

os.environ['GIT_OPTIONAL_LOCKS'] = '0'

# Options known to take a value as the next argument in git-diff.
# If these options are present, the next argument is skipped during revision parsing.
OPTIONS_WITH_ARGS: Set[str] = {
    "-S", "-G", "-O", "-U", "-c",
    "--color-words", "--word-diff-regex", "--output",
    "--diff-filter", "--relative", "--submodule", "--ws-error-highlight"
}

def print_help() -> None:
    """Prints a user-friendly help message with examples."""
    help_text = """git-meld - A Git diff tool wrapper using Meld for directory-level comparisons.

Usage:
  git-meld [<options>] [<commit> [<commit>]] [--] [<path>...]
  git-meld [<options>] <commit>..<commit> [--] [<path>...]
  git-meld [<options>] <commit>...<commit> [--] [<path>...]

Options:
  --cached, --staged      Compare staging area (index) instead of working directory.
  -h, --help              Show this help message and exit.
  --no-rename-detection   Disable rename detection mapping.

All other options (e.g. -w, --ignore-all-space) are passed through to `git diff`
to filter the list of files compared in Meld.

Examples:
  # Compare staging area to working directory:
  git-meld

  # Compare HEAD to staging area:
  git-meld --cached

  # Compare HEAD~1 to working directory:
  git-meld HEAD~1

  # Compare HEAD~1 to staging area:
  git-meld HEAD~1 --cached

  # Compare two commits/branches:
  git-meld master feature

  # Compare branch range:
  git-meld master..feature

  # Compare files in a specific directory only:
  git-meld master..feature -- src/
"""
    print(help_text)

def get_toplevel() -> str:
    """Returns the repository top-level absolute path."""
    try:
        res = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True,
            text=True,
            check=True
        )
        return res.stdout.strip()
    except subprocess.CalledProcessError as e:
        sys.stderr.write(e.stderr)
        sys.exit(e.returncode)

def is_valid_rev(ref: str) -> bool:
    """Checks if the given string is a valid git revision."""
    if not ref:
        return True  # Empty refs are defaulted to HEAD in ranges (e.g. ..B or A..)
    try:
        subprocess.run(
            ["git", "rev-parse", "--verify", "--quiet", ref],
            check=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )
        return True
    except subprocess.CalledProcessError:
        return False

def parse_rev_or_range(arg: str) -> bool:
    """Checks if the given string is a valid git revision or range."""
    if "..." in arg:
        parts = arg.split("...", 1)
        return is_valid_rev(parts[0]) and is_valid_rev(parts[1])
    elif ".." in arg:
        parts = arg.split("..", 1)
        return is_valid_rev(parts[0]) and is_valid_rev(parts[1])
    else:
        return is_valid_rev(arg)

def parse_arguments(args: List[str]) -> Tuple[List[str], List[str], bool, bool, bool]:
    """
    Parses arguments to extract revisions, pathspecs, cache options, rename-detection option, and help request.
    
    Returns:
        A tuple of (revisions, paths, is_cached, no_rename_detection, help_requested).
    """
    revisions: List[str] = []
    paths: List[str] = []
    is_cached: bool = False
    no_rename_detection: bool = False
    help_requested: bool = False
    
    if "-h" in args or "--help" in args:
        help_requested = True
        return revisions, paths, is_cached, no_rename_detection, help_requested

    i = 0
    in_paths = False
    while i < len(args):
        arg = args[i]
        
        if in_paths:
            paths.append(arg)
            i += 1
            continue
            
        if arg == "--":
            in_paths = True
            i += 1
            continue
            
        if arg.startswith("-"):
            if arg in {"--cached", "--staged"}:
                is_cached = True
            elif arg == "--no-rename-detection":
                no_rename_detection = True
            
            # Skip option and its argument if it takes one
            if arg in OPTIONS_WITH_ARGS:
                i += 2
                continue
            # For options like -O<file>, if written as "-O file", we skip "file"
            if arg[:2] in {"-S", "-G", "-O", "-U"}:
                if len(arg) == 2:
                    i += 2
                else:
                    i += 1
                continue
                
            i += 1
            continue
        
        # Positional argument: check if it's a revision/range or pathspec
        has_range = any(".." in r or "..." in r for r in revisions)
        num_revs = len(revisions)
        
        if (num_revs < 2 and not has_range) and parse_rev_or_range(arg):
            revisions.append(arg)
        else:
            in_paths = True
            paths.append(arg)
        i += 1
        
    return revisions, paths, is_cached, no_rename_detection, help_requested

def query_diff_status(user_args: List[str], no_rename_detection: bool = False) -> Tuple[List[str], List[str], Dict[str, str]]:
    """
    Queries git diff for changed files and renames.
    
    Rename Detection & Alignment in Directory Diff (git-meld):
    Normally, external directory diff tools like Meld compare directory structures 
    by matching exact file paths. They do not have built-in Git rename metadata, so 
    renamed files (e.g. 'src_path' to 'dest_path') are displayed as a deletion 
    on the left pane and an addition on the right pane. This prevents side-by-side diffing.
    
    To solve this:
      1. We query git diff using '-z --raw' (without '--no-renames' by default).
      2. If a file is renamed, Git outputs status 'Rxxx' followed by 'src_path' and 'dest_path'.
      3. We add the old 'src_path' to the source list (so it is copied into source_dir), 
         and the new 'dest_path' to the destination list (so it is copied/linked to dest_dir).
      4. We record the mapping in 'rename_map': {dest_path: src_path}.
      5. Later, in main(), we copy the extracted 'src_path' snapshot to the path 'dest_path'
         inside the source_dir.
      6. Consequently, both source_dir and dest_dir will have 'dest_path' (the renamed file).
         Meld will then show 'dest_path' as a modified file, allowing a side-by-side diff.
      7. The old 'src_path' is still kept in source_dir and is absent in dest_dir, so it
         shows up as a deletion, which correctly communicates the rename.
    
    If 'no_rename_detection' is True, we pass '--no-renames' to Git diff, causing Git to 
    treat renames as separate deletion ('D') and addition ('A') events. No alignment is performed.
    
    Returns:
        src_files: Files to copy to source_dir
        dest_files: Files to copy/link to dest_dir
        rename_map: Dict mapping dest_path -> src_path
    """
    cmd = ["git", "diff", "-z", "--raw"]
    if no_rename_detection:
        cmd.append("--no-renames")
    cmd += user_args
    try:
        res = subprocess.run(cmd, capture_output=True, check=True)
    except subprocess.CalledProcessError as e:
        sys.stderr.write(e.stderr.decode('utf-8', errors='replace'))
        sys.exit(e.returncode)
        
    parts = res.stdout.split(b'\0')
    if parts and parts[-1] == b'':
        parts.pop()
        
    src_files: List[str] = []
    dest_files: List[str] = []
    rename_map: Dict[str, str] = {}
    
    i = 0
    while i < len(parts):
        status_part = parts[i]
        if not status_part:
            i += 1
            continue
        status_str = status_part.decode('utf-8', errors='replace')
        
        is_submodule = False
        if status_str.startswith(':'):
            # Parse raw format: :<src-mode> <dst-mode> <src-sha> <dst-sha> <status>
            meta_parts = status_str.split()
            if len(meta_parts) >= 5:
                src_mode = meta_parts[0][1:]
                dst_mode = meta_parts[1]
                status = meta_parts[4]
                if src_mode == '160000' or dst_mode == '160000':
                    is_submodule = True
            else:
                status = status_str
        else:
            status = status_str
            
        if status.startswith('R') or status.startswith('C'):
            if i + 2 < len(parts):
                src_path = parts[i+1].decode('utf-8', errors='replace')
                dest_path = parts[i+2].decode('utf-8', errors='replace')
                if not is_submodule:
                    if status.startswith('R'):
                        src_files.append(src_path)
                        dest_files.append(dest_path)
                        rename_map[dest_path] = src_path
                    else:
                        dest_files.append(dest_path)
                i += 3
            else:
                break
        else:
            if i + 1 < len(parts):
                path = parts[i+1].decode('utf-8', errors='replace')
                if not is_submodule:
                    if status == 'D':
                        src_files.append(path)
                    elif status == 'A':
                        dest_files.append(path)
                    elif status in {'M', 'T', 'U', 'X', 'B'}:
                        src_files.append(path)
                        dest_files.append(path)
                i += 2
            else:
                break
                
    return src_files, dest_files, rename_map


def copy_files_named_tree(tree: str, file_list: List[str], out_dir: str) -> None:
    """Extracts files from a named tree (commit, tag, etc.) to the output directory."""
    if not file_list:
        return
    toplevel = get_toplevel()
    cmd = ["git", "archive", "--format=tar", tree] + file_list
    res = subprocess.run(cmd, cwd=toplevel, capture_output=True, check=True)
    with tarfile.open(fileobj=io.BytesIO(res.stdout)) as tar:
        try:
            tar.extractall(path=out_dir, filter='fully_trusted')
        except TypeError:
            tar.extractall(path=out_dir)

def copy_files_staging_area(file_list: List[str], out_dir: str) -> None:
    """Extracts files from the staging area to the output directory."""
    if not file_list:
        return
    toplevel = get_toplevel()
    prefix = os.path.abspath(out_dir) + os.sep
    cmd = ["git", "checkout-index", f"--prefix={prefix}", "--stdin", "-z"]
    input_data = "\0".join(file_list).encode('utf-8') + b"\0"
    subprocess.run(cmd, cwd=toplevel, input=input_data, check=True)

def link_files_working_dir(file_list: List[str], out_dir: str) -> None:
    """Creates symlinks from the working directory to the output directory."""
    toplevel = get_toplevel()
    for filename in file_list:
        src_path = os.path.abspath(os.path.join(toplevel, filename))
        dest_path = os.path.abspath(os.path.join(out_dir, filename))
        os.makedirs(os.path.dirname(dest_path), exist_ok=True)
        if os.path.exists(dest_path) or os.path.islink(dest_path):
            os.remove(dest_path)
        os.symlink(src_path, dest_path)

def sanitize_dir_name(name: str) -> str:
    """Sanitizes directory name to keep it flat and safe."""
    for c in ['/', '\\', ':', '*', '?', '"', '<', '>', '|']:
        name = name.replace(c, '_')
    return name

def make_readonly_recursive(path: str) -> None:
    """Recursively removes write permission from files and directories, avoiding symlinks."""
    for root, dirs, files in os.walk(path):
        for name in files:
            file_path = os.path.join(root, name)
            if not os.path.islink(file_path):
                try:
                    mode = os.stat(file_path).st_mode
                    os.chmod(file_path, mode & ~stat.S_IWRITE)
                except OSError:
                    pass
        for name in dirs:
            dir_path = os.path.join(root, name)
            if not os.path.islink(dir_path):
                try:
                    mode = os.stat(dir_path).st_mode
                    os.chmod(dir_path, mode & ~stat.S_IWRITE)
                except OSError:
                    pass

def make_writable_recursive(path: str) -> None:
    """Recursively adds write permission to files and directories, avoiding symlinks."""
    for root, dirs, files in os.walk(path):
        for name in files:
            file_path = os.path.join(root, name)
            if not os.path.islink(file_path):
                try:
                    mode = os.stat(file_path).st_mode
                    os.chmod(file_path, mode | stat.S_IWRITE)
                except OSError:
                    pass
        for name in dirs:
            dir_path = os.path.join(root, name)
            if not os.path.islink(dir_path):
                try:
                    mode = os.stat(dir_path).st_mode
                    os.chmod(dir_path, mode | stat.S_IWRITE)
                except OSError:
                    pass

def get_git_config(key: str, default: str) -> str:
    """Reads a git config value, returning default if not set."""
    try:
        res = subprocess.run(
            ["git", "config", "--get", key],
            capture_output=True,
            text=True,
            check=True
        )
        val = res.stdout.strip()
        return val if val else default
    except subprocess.CalledProcessError:
        return default

def main() -> None:
    user_args = sys.argv[1:]
    revisions, paths, is_cached, no_rename_detection, help_requested = parse_arguments(user_args)
    
    if help_requested:
        print_help()
        sys.exit(0)

    # Determine source and destination trees and name identifiers
    source_tree = ""
    dest_tree = ""
    source_name = "staging_area"
    dest_name = "working_dir"

    if len(revisions) == 1:
        range_str = revisions[0]
        if "..." in range_str:
            parts = range_str.split("...", 1)
            left = parts[0] if parts[0] else "HEAD"
            right = parts[1] if parts[1] else "HEAD"
            try:
                res = subprocess.run(
                    ["git", "merge-base", left, right],
                    capture_output=True,
                    text=True,
                    check=True
                )
                source_tree = res.stdout.strip()
            except subprocess.CalledProcessError as e:
                sys.stderr.write(e.stderr)
                sys.exit(e.returncode)
            dest_tree = right
            source_name = f"{left}...{right}_base"
            dest_name = right
        elif ".." in range_str:
            parts = range_str.split("..", 1)
            left = parts[0] if parts[0] else "HEAD"
            right = parts[1] if parts[1] else "HEAD"
            source_tree = left
            dest_tree = right
            source_name = left
            dest_name = right
        else:
            source_tree = range_str
            source_name = range_str
            if is_cached:
                dest_name = "staging_area"
            else:
                dest_name = "working_dir"
    elif len(revisions) == 2:
        source_tree = revisions[0]
        dest_tree = revisions[1]
        source_name = revisions[0]
        dest_name = revisions[1]
    else:
        # No revisions
        if is_cached:
            source_tree = "HEAD"
            source_name = "HEAD"
            dest_name = "staging_area"
        else:
            source_name = "staging_area"
            dest_name = "working_dir"

    # Enforce one commit constraint with --cached/--staged
    if is_cached:
        if dest_tree:
            sys.stderr.write(
                f"Error: Only one commit can be given with the option --cached or --staged. "
                f"You gave '{source_tree}' and '{dest_tree}'.\n"
            )
            sys.exit(1)

    # Filter arguments to pass to git diff (exclude -h, --help, and --no-rename-detection)
    filtered_diff_args = [arg for arg in user_args if arg not in {"-h", "--help", "--no-rename-detection"}]

    # Query changed files
    src_changed_files, dest_changed_files, rename_map = query_diff_status(filtered_diff_args, no_rename_detection)

    # If no changes are found, we can exit early
    if not src_changed_files and not dest_changed_files:
        print("No changes found.")
        sys.exit(0)

    # Create temporary directory structure
    tmp_dir = tempfile.mkdtemp(prefix="git-meld-")
    try:
        source_dir = os.path.join(tmp_dir, sanitize_dir_name(source_name))
        dest_dir = os.path.join(tmp_dir, sanitize_dir_name(dest_name))
        
        os.makedirs(source_dir, exist_ok=True)
        os.makedirs(dest_dir, exist_ok=True)

        # Populate source directory
        if not source_tree:
            copy_files_staging_area(src_changed_files, source_dir)
        else:
            copy_files_named_tree(source_tree, src_changed_files, source_dir)

        # Populate destination directory
        if is_cached:
            copy_files_staging_area(dest_changed_files, dest_dir)
        elif not dest_tree:
            link_files_working_dir(dest_changed_files, dest_dir)
        else:
            copy_files_named_tree(dest_tree, dest_changed_files, dest_dir)

        # Align renamed files in source directory so Meld can diff them
        for dest_path, src_path in rename_map.items():
            src_full = os.path.join(source_dir, src_path)
            dest_full_in_src = os.path.join(source_dir, dest_path)
            if os.path.exists(src_full):
                os.makedirs(os.path.dirname(dest_full_in_src), exist_ok=True)
                shutil.copy2(src_full, dest_full_in_src)

        # Protect historical revisions from editing (make them read-only)
        if not source_tree:
            # Staging area is read-only
            make_readonly_recursive(source_dir)
        else:
            # Historical commit is read-only
            make_readonly_recursive(source_dir)

        if is_cached or dest_tree:
            # Staging area or historical commit in destination is read-only
            make_readonly_recursive(dest_dir)

        # Find and run the tree diff tool
        tool = get_git_config("treediff.tool", "meld")
        cmd = get_git_config(f"treediff.{tool}.cmd", tool)
        path = get_git_config(f"treediff.{tool}.path", "")
        
        exec_path = os.path.join(path, cmd) if path else cmd
        cmd_args = shlex.split(exec_path)
        
        if not cmd_args:
            sys.stderr.write("Error: No diff tool specified.\n")
            sys.exit(1)

        tool_executable = cmd_args[0]
        if not shutil.which(tool_executable):
            sys.stderr.write(
                f"Error: Could not find diff tool '{tool_executable}'. "
                f"Please make sure it is installed and in your PATH.\n"
            )
            sys.exit(1)

        try:
            pid = os.fork()
            if pid > 0:
                # Parent process exits immediately, bypassing cleanup so the child can use the files
                os._exit(0)
        except OSError as e:
            sys.stderr.write(f"Fork failed: {e}\n")
            sys.exit(1)

        # Child process: decouple from the parent's session/terminal
        try:
            os.setsid()
        except OSError:
            pass

        try:
            subprocess.run(
                cmd_args + [source_dir, dest_dir],
                stdin=subprocess.DEVNULL,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                check=True
            )
        except subprocess.CalledProcessError as e:
            sys.exit(e.returncode)
            
    finally:
        # Cleanup temporary files
        make_writable_recursive(tmp_dir)
        shutil.rmtree(tmp_dir, ignore_errors=True)

if __name__ == "__main__":
    main()
