#!/bin/bash
# dconf-restore: Convert dconf-backup output to a format importable by `dconf load /`.
# Reads from stdin, writes to stdout.
# Run tests: bash misc/dconf-restore_test.bash

if [[ "${1-}" == -h || "${1-}" == --help ]]; then
  echo "See \`dconf-backup -h\` for more details."
  exit 0
fi

# Three sed expressions:
#   1. Strip path prefix from key lines (starting with /):
#      Remove leading / plus zero-or-more path components (non-= chars + /),
#      leaving just keyname=value.  Zero iterations handles root-level keys (/key=val).
#   2-3. Expand '$HOME' back to the real home directory (longer form first).
sed -E "s|^/([^=]*/)*||; s|'\\\$HOME/|'$HOME/|g; s|'\\\$HOME|'$HOME|g"
