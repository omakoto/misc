#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
dconf-restore: Convert dconf-backup output into a format importable by `dconf load /`.

This script is a text filter. It reads a dconf-backup file (from a file argument or
stdin) and transforms it back to standard dconf load format:
  - Section headers are passed through unchanged.
  - Key path prefixes are stripped, leaving only the leaf key name.
  - '$HOME' in values is expanded back to the real home directory.

Usage examples:
  # Restore all settings from a backup file:
  dconf-restore settings.dconf | dconf load /

  # Read from stdin:
  cat settings.dconf | dconf-restore | dconf load /

  # Pipe dconf-backup directly into dconf-restore and load:
  dconf-backup /org/cinnamon/ | dconf-restore | dconf load /

  # Restore only a specific subtree:
  grep -A1000 '\\[org/cinnamon/desktop/keybindings\\]' settings.dconf \\
      | dconf-restore | dconf load /

Run tests before modifying:
  python3 misc/dconf-restore_test.py
"""

import argparse
import os
import signal
import sys
from typing import TextIO


# Graceful SIGPIPE handling (e.g. when piped to head)
try:
    signal.signal(signal.SIGPIPE, signal.SIG_DFL)
except AttributeError:
    pass


def expand_home(line: str, home: str) -> str:
    """Expand '$HOME' back to the real home directory in string values.

    Only replaces occurrences following a single quote (dconf string value format).
    The longer form (with trailing slash) is replaced first.

    Args:
        line: A key=value line with possible '$HOME' references.
        home: The real home directory path (e.g. '/home/omakoto').

    Returns:
        The line with '$HOME' expanded to the real path.
    """
    line = line.replace("'$HOME/", f"'{home}/")
    line = line.replace("'$HOME", f"'{home}")
    return line


def strip_key_prefix(line: str) -> str:
    """Strip the path prefix from a dconf-backup key=value line.

    In dconf-backup output, keys look like:
      /org/cinnamon/desktop/keybindings/custom-list=['val1', 'val2']

    This function strips everything up to and including the last '/' before
    the '=' sign, returning just:
      custom-list=['val1', 'val2']

    Args:
        line: A full key=value line starting with '/'.

    Returns:
        The line with only the leaf key name (path prefix removed).
    """
    eq_pos = line.find('=')
    if eq_pos == -1:
        # No '=' found — unexpected; pass through unchanged.
        return line

    key_path = line[:eq_pos]          # e.g. /org/.../custom-list
    value_part = line[eq_pos:]        # e.g. =['val1', 'val2']

    # Take the last component of the path as the leaf key name.
    leaf_key = key_path.rsplit('/', 1)[-1]
    return leaf_key + value_part


def process_line(line: str, home: str) -> str:
    """Process a single line of dconf-backup output for dconf load / consumption.

    Args:
        line: One line from the dconf-backup file (including newline if present).
        home: The real home directory path.

    Returns:
        The transformed line.
    """
    stripped = line.rstrip('\n')

    # Section header [org/path/...]: pass through unchanged.
    # dconf-backup already produces valid headers (no leading/trailing slash,
    # except for the special [/] root case).
    if stripped.startswith('[') and stripped.endswith(']'):
        return line

    # Blank line: pass through.
    if stripped == '':
        return line

    # Key=value line (starts with '/' in dconf-backup format).
    if stripped.startswith('/'):
        stripped = strip_key_prefix(stripped)
        stripped = expand_home(stripped, home)
        return stripped + '\n'

    # Anything else (e.g. comments or unexpected content): pass through.
    return line


def process_input(inp: TextIO, home: str) -> None:
    """Process all lines from the input stream and write to stdout.

    Args:
        inp: Readable text stream (file or stdin).
        home: The real home directory path.
    """
    for line in inp:
        sys.stdout.write(process_line(line, home))


def main() -> None:
    parser = argparse.ArgumentParser(
        prog='dconf-restore',
        description=(
            'Convert dconf-backup output into a format importable by dconf load /.\n'
            'Reads from FILE (or stdin if omitted). Pipe the output to: dconf load /'
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
Examples:
  # Restore all settings from a backup file:
  dconf-restore settings.dconf | dconf load /

  # Read from stdin:
  cat settings.dconf | dconf-restore | dconf load /

  # Backup and restore in one pipeline:
  dconf-backup /org/cinnamon/ | dconf-restore | dconf load /

  # Restore only a specific subtree:
  grep -A1000 '\\[org/cinnamon/desktop/keybindings\\]' settings.dconf \\
      | dconf-restore | dconf load /
""")

    parser.add_argument(
        'file', metavar='FILE', nargs='?',
        help='dconf-backup file to read (default: stdin)')

    args = parser.parse_args()
    home = os.environ.get('HOME', os.path.expanduser('~'))

    if args.file:
        try:
            with open(args.file, 'r', encoding='utf-8') as f:
                process_input(f, home)
        except FileNotFoundError:
            print(f'Error: file not found: {args.file!r}', file=sys.stderr)
            sys.exit(1)
        except OSError as e:
            print(f'Error: cannot read {args.file!r}: {e}', file=sys.stderr)
            sys.exit(1)
    else:
        process_input(sys.stdin, home)


if __name__ == '__main__':
    try:
        main()
    except KeyboardInterrupt:
        sys.exit(1)
    except BrokenPipeError:
        sys.exit(0)
