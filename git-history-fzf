#!/usr/bin/env python3
# -*- coding: utf-8 -*-
# Reusable interactive Git history selector using fzf.
# Displays commits with hash, author date, author email, and branch decorations.
# Returns the selected key on the first line (if -e is used), and selected commits on subsequent lines.
#
# Make sure to run git-history-fzf_test.py after making any changes.
#
# Examples:
#   git-history-fzf -c -h "Select commits"
#   git-history-fzf --help

import sys
import os
import subprocess
import argparse
import re
import shlex
from typing import List, Set, Optional, Any
from functools import lru_cache

os.environ['GIT_OPTIONAL_LOCKS'] = '0'

_fzf_active = False

def run_command(cmd: List[str], **kwargs: Any) -> subprocess.CompletedProcess[Any]:
    if not _fzf_active:
        sys.stderr.write(f"+ {shlex.join(cmd)}\n")
        sys.stderr.flush()
    return subprocess.run(cmd, **kwargs)

def popen_command(cmd: List[str], **kwargs: Any) -> subprocess.Popen[Any]:
    if not _fzf_active:
        sys.stderr.write(f"+ {shlex.join(cmd)}\n")
        sys.stderr.flush()
    return subprocess.Popen(cmd, **kwargs)

def terminate_process(proc: Optional[subprocess.Popen[Any]]) -> None:
    if proc is not None and proc.poll() is None:
        proc.terminate()
        try:
            proc.wait(timeout=0.2)
        except subprocess.TimeoutExpired:
            proc.kill()
            proc.wait()

def is_inside_work_tree() -> bool:
    """Checks if the current working directory is inside a Git work tree."""
    res = run_command(
        ["git", "rev-parse", "--is-inside-work-tree"],
        capture_output=True
    )
    return res.returncode == 0

def is_dirty() -> bool:
    """Checks if the Git repository has any uncommitted changes."""
    if run_command(["git", "diff-files", "--quiet"]).returncode != 0:
        return True
    if run_command(["git", "diff-index", "--cached", "--quiet", "HEAD"]).returncode != 0:
        return True
    
    proc = popen_command(["git", "ls-files", "--others", "--exclude-standard"], stdout=subprocess.PIPE)
    is_dirty = False
    if proc.stdout is not None:
        first_line = proc.stdout.readline()
        terminate_process(proc)
        if first_line:
            is_dirty = True
    return is_dirty

def get_merge_bases() -> Set[bytes]:
    """Retrieves the merge base commit SHAs with the upstream branch."""
    try:
        res = run_command(
            ["git", "merge-base", "HEAD", "@{u}"],
            capture_output=True
        )
        if res.returncode == 0:
            return {line.strip() for line in res.stdout.splitlines() if line.strip()}
    except Exception:
        pass
    return set()

def format_line(line: bytes, merge_bases: Optional[Set[bytes]] = None) -> bytes:
    """Formats a single line from git log for fzf selection."""
    line = line.rstrip(b"\n")
    parts = line.split(b"\x00")
    if len(parts) < 5:
        return line + b"\n"
        
    hash_part, date_part, email_part, deco_part, subject_part = parts[0], parts[1], parts[2], parts[3], parts[4]
    
    formatted_date = b"\x1b[36m[" + date_part + b"]\x1b[m"
    formatted_email = b"\x1b[35m<" + email_part + b">\x1b[m"
    
    # Strip ANSI escape codes from decoration part
    clean_deco = re.sub(br"\x1b\[[0-9;]*m", b"", deco_part).strip()
    
    # Check if this commit is the merge base with upstream
    is_mb = False
    if merge_bases and hash_part:
        clean_hash = re.sub(br"\x1b\[[0-9;]*m", b"", hash_part).strip()
        hash_str = clean_hash.decode('utf-8', errors='ignore')
        for mb in merge_bases:
            if mb.decode('utf-8', errors='ignore').startswith(hash_str):
                is_mb = True
                break

    branches: List[bytes] = []
    if clean_deco:
        for item in clean_deco.split(b","):
            item = item.strip()
            if not item or item.startswith(b"tag:"):
                continue
            if b"->" in item:
                left, right = item.split(b"->", 1)
                left, right = left.strip(), right.strip()
                if left != b"HEAD":
                    branches.append(left)
                branches.append(right)
            else:
                branches.append(item)
            
    unique_branches: List[bytes] = []
    for b in branches:
        if b not in unique_branches:
            unique_branches.append(b)
            
    if is_mb:
        if b"\x1b[33mupstream-base\x1b[32m" not in unique_branches:
            unique_branches.append(b"\x1b[33mupstream-base\x1b[32m")

    if unique_branches:
        green_deco = b"\x1b[32m[" + b", ".join(unique_branches) + b"]\x1b[m"
        return hash_part + b" " + formatted_date + b" " + formatted_email + b" " + green_deco + b" " + subject_part + b"\n"
    else:
        return hash_part + b" " + formatted_date + b" " + formatted_email + b" " + subject_part + b"\n"

@lru_cache(maxsize=1)
def _get_submodules_abs() -> List[str]:
    try:
        res = run_command(["git", "rev-parse", "--show-toplevel"], capture_output=True, text=True)
        if res.returncode != 0:
            return []
        toplevel = res.stdout.strip()
        
        gitmodules_path = os.path.join(toplevel, ".gitmodules")
        if not os.path.exists(gitmodules_path):
            return []
            
        res = run_command(
            ["git", "config", "--file", gitmodules_path, "--get-regexp", "path"],
            capture_output=True,
            text=True
        )
        if res.returncode != 0:
            return []
            
        subs = []
        for line in res.stdout.splitlines():
            line = line.strip()
            if not line:
                continue
            parts = line.split(None, 1)
            if len(parts) == 2:
                sub_path = parts[1]
                abs_sub_path = os.path.join(toplevel, sub_path)
                if os.path.exists(os.path.join(abs_sub_path, ".git")):
                    subs.append(abs_sub_path)
        return subs
    except Exception:
        pass
    return []

def get_submodules() -> List[str]:
    """Retrieves the list of submodule paths in the repository."""
    return [os.path.relpath(p, os.getcwd()) for p in _get_submodules_abs()]

def get_parent_repo() -> Optional[str]:
    """Retrieves the parent repository's working tree path, if in a submodule."""
    try:
        res = run_command(
            ["git", "rev-parse", "--show-superproject-working-tree"],
            capture_output=True,
            text=True
        )
        if res.returncode == 0:
            path = res.stdout.strip()
            return path if path else None
    except Exception:
        pass
    return None

def has_limit(args: List[str]) -> bool:
    """Checks if git log arguments already contain a limit (e.g. -n 100, -100, --max-count=100)."""
    for i, arg in enumerate(args):
        if arg == "-n" or arg == "--max-count":
            return True
        if arg.startswith("--max-count="):
            return True
        if re.match(r"^-\d+$", arg):
            return True
    return False

def normalize_path(path: str) -> str:
    """Normalize and shorten path using dir-normalize script."""
    script_dir = os.path.dirname(os.path.realpath(__file__))
    dir_normalize_path = os.path.join(script_dir, "dir-normalize")
    try:
        res = subprocess.run([dir_normalize_path, path], capture_output=True, text=True, check=True)
        return res.stdout.strip()
    except Exception:
        return path


def main_inner() -> None:
    global _fzf_active
    if sys.stderr.isatty():
        title = normalize_path(os.getcwd())
        sys.stderr.write(f"\033]0;Git history: {title}\007")
        sys.stderr.flush()

    if not is_inside_work_tree():
        sys.stderr.write("Error: Not a git repository\n")
        sys.exit(1)

    parser = argparse.ArgumentParser(
        description="Reusable interactive Git history selector using fzf.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        add_help=False,
        epilog="""\
Examples:
  git-history-fzf -c
  git-history-fzf -c --submodules
  git-history-fzf -s -h "Select a single commit"
  git-history-fzf -c -e ctrl-s -h "Select commits" -- --author="John"
"""
    )
    parser.add_argument("--help", action="help", help="show this help message and exit")
    parser.add_argument("-c", "--current", action="store_true", help="Include the '(CURRENT)' local changes line if workspace is dirty")
    parser.add_argument("--submodules", action="store_true", help="Include submodules at the top of the list")
    parser.add_argument("-h", "--header", help="Specify the header string for fzf")
    parser.add_argument("-s", "--single", action="store_true", help="Single-line select mode (disable multi-select)")
    parser.add_argument("-e", "--expect", help="Comma-separated list of keys to expect from fzf (like ctrl-s)")
    
    args, git_log_args = parser.parse_known_args()
    
    # Strip the leading '--' if it was used to separate options
    if git_log_args and git_log_args[0] == "--":
        git_log_args = git_log_args[1:]
        
    if not has_limit(git_log_args):
        git_log_args.insert(0, "5000")
        git_log_args.insert(0, "-n")

    # Construct fzf options
    fzf_cmd: List[str] = [
        "fzf",
        "--ansi",
        "--no-sort",
        "--preview",
        'case "{1}" in '
        '  *"(CURRENT)"*) '
        '    git status --short; '
        '    if command -v delta >/dev/null 2>&1; then '
        '      git diff --color=always HEAD | delta; '
        '    else '
        '      git diff --color=always HEAD; '
        '    fi; '
        '    ;; '
        '  *"(submodule)"*) '
        '    case "{2}" in '
        '      *"[Submodules]"*) '
        '        git submodule status | awk \'{print substr($0, 1, 1) substr($0, 42)}\'; '
        '        ;; '
        '      *"(Parent)"*) '
        '        parent_dir=$(git rev-parse --show-superproject-working-tree 2>/dev/null); '
        '        if [ -n "$parent_dir" ]; then '
        '          echo "Parent Repository: $parent_dir"; '
        '          echo; '
        '          git -C "$parent_dir" status; '
        '          echo; '
        '          git -C "$parent_dir" log -n 5 --oneline --color=always; '
        '        else '
        '          echo "No parent repository found."; '
        '        fi; '
        '        ;; '
        '      *) '
        '        echo "Submodule: {2}"; '
        '        echo; '
        '        git -C {2} status; '
        '        echo; '
        '        git -C {2} log -n 5 --oneline --color=always; '
        '        ;; '
        '    esac; '
        '    ;; '
        '  *) '
        '    if command -v delta >/dev/null 2>&1; then '
        '      git show --stat -p --color=always {1} | delta; '
        '    else '
        '      git show --stat -p --color=always {1}; '
        '    fi; '
        '    ;; '
        'esac',
        "--preview-window", "top:60%"
    ]
    
    if not args.single:
        fzf_cmd.append("--multi")
        
    if args.expect:
        fzf_cmd.append(f"--expect={args.expect}")
        
    if args.header:
        fzf_cmd.append(f"--header={args.header}")

    _fzf_active = True
    while True:
        # Start parallel checks for this iteration
        mb_proc = popen_command(["git", "merge-base", "HEAD", "@{u}"], stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
        
        df_proc = None
        di_proc = None
        lf_proc = None
        if args.current:
            df_proc = popen_command(["git", "diff-files", "--quiet"], stderr=subprocess.DEVNULL)
            di_proc = popen_command(["git", "diff-index", "--cached", "--quiet", "HEAD"], stderr=subprocess.DEVNULL)
            lf_proc = popen_command(["git", "ls-files", "--others", "--exclude-standard"], stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)

        # Start fzf process
        fzf_proc = popen_command(
            fzf_cmd,
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            text=False
        )

        # Start git log process
        git_cmd: List[str] = [
            "git", "log", "--color=always",
            "--date=format:%Y-%m-%d %H:%M:%S",
            "--format=%C(auto)%h%x00%ad%x00%aE%x00%D%x00%C(auto)%s"
        ] + git_log_args

        git_proc = popen_command(
            git_cmd,
            stdout=subprocess.PIPE,
            text=False
        )

        try:
            if fzf_proc.stdin is not None:
                # Resolve is_dirty
                is_dirty_val = False
                if args.current and df_proc and di_proc and lf_proc:
                    if df_proc.wait() != 0:
                        is_dirty_val = True
                    
                    if not is_dirty_val:
                        if di_proc.wait() != 0:
                            is_dirty_val = True
                    else:
                        terminate_process(di_proc)
                        
                    if not is_dirty_val:
                        first_line = lf_proc.stdout.readline() if lf_proc.stdout else b""
                        if first_line:
                            is_dirty_val = True
                        terminate_process(lf_proc)
                    else:
                        terminate_process(lf_proc)
                        
                if args.current and is_dirty_val:
                    fzf_proc.stdin.write(b"\x1b[33m(CURRENT)\x1b[m Local changes\n")
                
                # Resolve merge bases
                merge_bases = set()
                try:
                    mb_out, _ = mb_proc.communicate()
                    if mb_proc.returncode == 0:
                        merge_bases = set(mb_out.splitlines())
                except Exception:
                    pass
                
                if args.submodules:
                    parent_repo = get_parent_repo()
                    if parent_repo:
                        fzf_proc.stdin.write(b"\x1b[35m(submodule)\x1b[m (Parent)\n")
                    subs = get_submodules()
                    if subs:
                        fzf_proc.stdin.write(b"\x1b[35m(submodule)\x1b[m [Submodules]\n")
                
                # Flush initial items to ensure they show up immediately
                fzf_proc.stdin.flush()
                
                if git_proc.stdout is not None:
                    for line in git_proc.stdout:
                        fzf_proc.stdin.write(format_line(line, merge_bases))
                        fzf_proc.stdin.flush()
                
                fzf_proc.stdin.close()
        except BrokenPipeError:
            pass

        fzf_output, _ = fzf_proc.communicate()
        fzf_code = fzf_proc.wait()
        terminate_process(git_proc)
        terminate_process(mb_proc)
        terminate_process(df_proc)
        terminate_process(di_proc)
        terminate_process(lf_proc)

        if fzf_code != 0:
            sys.exit(fzf_code)

        # Parse selections
        lines = fzf_output.split(b"\n")
        if lines and lines[-1] == b"":
            lines.pop()

        selections = lines[1:] if args.expect else lines
        has_submodules_trigger = False
        for sel in selections:
            if b"(submodule) [Submodules]" in sel:
                has_submodules_trigger = True
                break

        if has_submodules_trigger:
            fzf_sub_cmd = [
                "fzf",
                "--ansi",
                "--no-sort",
                "--header=Select a submodule to view its history",
                "--preview",
                "echo 'Submodule: {1}'; echo; git -C {1} status; echo; git -C {1} log -n 5 --oneline --color=always",
                "--preview-window", "top:60%"
            ]
            fzf_sub_proc = popen_command(
                fzf_sub_cmd,
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                text=False
            )
            try:
                if fzf_sub_proc.stdin is not None:
                    for sub in get_submodules():
                        fzf_sub_proc.stdin.write(f"{sub}\n".encode('utf-8'))
                    fzf_sub_proc.stdin.close()
            except BrokenPipeError:
                pass

            sub_output, _ = fzf_sub_proc.communicate()
            sub_code = fzf_sub_proc.wait()

            if sub_code == 0:
                selected_sub = sub_output.strip()
                if args.expect:
                    sys.stdout.buffer.write(b"\n(submodule) " + selected_sub + b"\n")
                else:
                    sys.stdout.buffer.write(b"(submodule) " + selected_sub + b"\n")
                sys.stdout.buffer.flush()
                sys.exit(0)
            else:
                # User cancelled submodules selector, return to main loop
                continue
        else:
            sys.stdout.buffer.write(fzf_output)
            sys.stdout.buffer.flush()
            sys.exit(0)

def main() -> None:
    global _fzf_active
    try:
        main_inner()
    finally:
        _fzf_active = False

if __name__ == "__main__":
    main()
