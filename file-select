#!/bin/bash

# Show files under the current dir and let the user pick files with fzf.
# The selected file names are printed to stdout and copied to the clipboard.
#
# Simple script, no help needed.

set -e
. mutil.sh

# Temporary file to store the view state.
STATE_FILE=$(mktemp)
export STATE_FILE
trap 'rm -f "$STATE_FILE"' EXIT

# Initial state is fullpath.
echo "fullpath" > "$STATE_FILE"

selected=$(list-files --colors always --show-fullpath --no-show-relative-path --show-directories 2>/dev/null | fzf --multi --ansi "$@" \
  --header "Ctrl-A: Toggle fullpath / relpath" \
  --bind "ctrl-a:reload(bash -c '
    state=\$(cat \"\$STATE_FILE\")
    if [[ \"\$state\" == \"fullpath\" ]]; then
      echo \"relpath\" > \"\$STATE_FILE\"
      list-files --colors always --no-show-fullpath --show-directories 2>/dev/null
    else
      echo \"fullpath\" > \"\$STATE_FILE\"
      list-files --colors always --show-fullpath --no-show-relative-path --show-directories 2>/dev/null
    fi
  ')")

if [[ -n "$selected" ]]; then
  echo "$selected" | cb
  echo "$selected"
fi

