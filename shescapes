#!/bin/bash

# Escape standard input or file lines for the shell, printing space-separated arguments.
#
# Run the test script before committing: ./shescapes_test.bash
#
# Simple script, no help needed.

has_input=0

process_stream() {
    local line
    while IFS= read -r line || [[ -n "$line" ]]; do
        printf "%q " "$line"
        has_input=1
    done
}

if (( $# == 0 )); then
    process_stream
else
    for file in "$@"; do
        if [[ "$file" == "-" ]]; then
            process_stream
        else
            process_stream < "$file"
        fi
    done
fi

if (( has_input )); then
    echo
fi
