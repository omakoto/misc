#!/bin/bash

. $(dirname "$0")/reenv.bash

num_tests=0
num_failure=0

function test() {
    (( ++num_tests))

    local label="$1"
    local run="$2"
    local expected="$3"

    echo "================"
    echo "Test: $label"
    echo "================"

    local actual="$(eval "$run" 2>&1)"
    rc=$?

    diff -c <(echo "$expected") <(echo "$actual")
    rc=$?
    if (( $rc == 0 )); then
        echo "PASSED"
    else
        (( ++num_failure))
        echo "FAILED! Actual:"
        echo "------------"
        echo "$actual"
        echo "------------"
    fi
}


test "Call without base" '
reenv-cap
echo $?
' 'Use reenv-base to capture the base line environment first!
1'


test "No env change" '
reenv-base
echo $?
reenv-cap
echo $?
' '0
0'

test "Basic env change" '

changed=orig
reenv-base
echo $?

aaa="abc"
export XXX="xyz def"
changed=new

reenv-cap
echo $?
' '0
#XXX
declare -x XXX="xyz def"
#aaa
declare -- aaa="abc"
#changed
declare -- changed="new"
0'

test "Basic env and func change" '

function a() { echo ok; }

reenv-base
echo $?

function a() { echo not ok; }
function b() { echo ok; }
var=xxx

reenv-cap
echo $?
' '0
#a()
a () 
{ 
    echo not ok
}
#b()
b () 
{ 
    echo ok
}
#var
declare -- var="xxx"
0'



if (( $num_failure == 0 )) && (( $num_tests > 0 )) ; then
    echo "ALL TESTS PASSED!"
    exit 0
fi

echo "$(( $num_failure )) / $(( $num_tests )) TESTS FAILED!"
exit 1
