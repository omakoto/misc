#!/bin/bash
# Shortcut script to execute git-meld-history.
# Simple script, no help needed.
# Run gg_test.bash after making any changes.

# Make sure the target directory is a git repository (unless it's a help flag)
# We want to show the error to the caller app (agy) directly, rather than showing
# the message in gnome-terminal.
if [[ "$1" == "-h" || "$1" == "--help" || "$1" == "--bash-completion" ]]; then
  :
else
  target_dir="."
  for arg in "$@"; do
    if [[ "$arg" != -* ]]; then
      target_dir="$arg"
      break
    fi
  done

  if [[ -d "$target_dir" ]]; then
    if ! git -C "$target_dir" rev-parse --is-inside-work-tree &>/dev/null; then
      echo "Error: '$target_dir' is not a git repository." >&2
      exit 1
    fi
  else
    if ! git rev-parse --is-inside-work-tree &>/dev/null; then
      echo "Error: Directory '$target_dir' does not exist." >&2
      exit 1
    fi
    if ! git rev-parse --verify --quiet "$target_dir"^{commit} &>/dev/null; then
      echo "Error: '$target_dir' is not a directory or a valid git reference." >&2
      exit 1
    fi
  fi
fi

# When run inside Antigravity/Claude, it launches in a new gnome-terminal.
if needs-term; then
  exec term --geometry=140x45 --no-wait -- gg "$@"
fi

auto-term-close-on-idle

exec git meld-history "$@"
