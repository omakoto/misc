#!/bin/bash
#
# task-history - Interactive tasklog selector.
# Lists files in ~/history/tasklog/ and lets the user select one in fzf.
# The preview pane renders markdown files using pandoc if available.
# The selected file is opened using '1'.
#
# Run the test suite via `misc/task-history_test.bash` whenever making changes.
#

set -o pipefail

usage() {
  cat <<EOF

  task-history: Interactive tasklog selector.

  Usage: task-history [options] [query]

  Options:
    -h, --help    Show this help message.

  Examples:
    task-history
    task-history planning
EOF
}

# Parse options using GNU getopt
TEMP=$(getopt -o 'h' --long 'help,preview-file:' -n 'task-history' -- "$@")
if [[ $? -ne 0 ]]; then
  echo "Error parsing options." >&2
  exit 1
fi
eval set -- "$TEMP"

preview_file=""
while true; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --preview-file)
      preview_file="$2"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    *)
      echo "Internal error!" >&2
      exit 1
      ;;
  esac
done

query="$*"

TASKLOG_DIR="${TASKLOG_DIR:-$HOME/history/tasklog}"
TASKLOG_DIR="${TASKLOG_DIR%/}"

if [[ ! -d "$TASKLOG_DIR" ]]; then
  echo "Error: Directory '$TASKLOG_DIR' does not exist." >&2
  exit 1
fi

_task_history_preview() {
  local file="${1/#\~/$HOME}"
  glow2 --color=always "$file"
}

if [[ -n "$preview_file" ]]; then
  _task_history_preview "$preview_file"
  exit 0
fi

# Relaunch in term if needed (e.g. running under agent or non-terminal)
if needs-term; then
  exec term --geometry=160x45 --no-wait -- "$0" "$@"
fi

REAL_SCRIPT=$(readlink -f "$0")


prowl_args=(
  "--preview-height" "70%"
  "--sort=path-desc"
  "--preview" "glow2 --color=always {}"
  "-f" "*.md"
)
if [[ -n "$query" ]]; then
  prowl_args+=("--query" "$query")
fi

auto-term-close-on-idle

selected="$(
  prowl "${prowl_args[@]}" "$TASKLOG_DIR" "$HOME/.gemini/antigravity-cli/brain"
)"

if [[ -n "$selected" ]]; then
  exec 1 "${selected}"
fi

