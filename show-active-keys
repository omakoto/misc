#!/usr/bin/env python3
#
# This script scans all keyboard devices under /dev/input/event* and queries
# their current active (pressed) keys. The keys are printed one per line,
# globally sorted and deduplicated, with the "KEY_" prefix stripped.
#
# Every time this script is modified, run the corresponding test script:
#   python3 show-active-keys_test.py
#

import sys
from typing import Set
import evdev
from evdev import ecodes

def is_keyboard(device: evdev.InputDevice) -> bool:
    """Determine if a device is a keyboard based on its capabilities."""
    try:
        caps = device.capabilities()
        if ecodes.EV_KEY not in caps:
            return False
        # Count keys with code < 256 (standard alphanumeric/modifier keys)
        kbd_keys = [k for k in caps[ecodes.EV_KEY] if isinstance(k, int) and k < 256]
        return len(kbd_keys) > 20
    except Exception:
        return False

def get_active_keys() -> Set[str]:
    """Query all active keys from all keyboard devices."""
    active_keys: Set[str] = set()
    try:
        paths = evdev.list_devices()
    except Exception as e:
        print(f"Error listing devices: {e}", file=sys.stderr)
        return active_keys

    for path in paths:
        try:
            device = evdev.InputDevice(path)
        except Exception:
            continue
        if is_keyboard(device):
            try:
                for code in device.active_keys():
                    name_entry = ecodes.KEY.get(code, None)
                    if name_entry:
                        if isinstance(name_entry, list):
                            name = name_entry[0]
                        else:
                            name = name_entry
                        
                        if name.startswith("KEY_"):
                            name = name[4:]
                        active_keys.add(name)
                    else:
                        active_keys.add(f"UNKNOWN_{code}")
            except Exception:
                pass
    return active_keys

def main() -> None:
    if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help"):
        print("Usage: show-active-keys\n")
        print("Prints all currently pressed keys across all keyboard devices,")
        print("one key per line, sorted and unique.\n")
        print("Example:")
        print("  show-active-keys")
        sys.exit(0)

    keys = sorted(list(get_active_keys()))
    for key in keys:
        print(key)

if __name__ == "__main__":
    main()
