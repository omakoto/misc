#!/usr/bin/env python3
# Interactive ANSI color picker.
#
# Run the test script every time touching this file: python3 color-picker-test.py
#
# Allows selecting Foreground and Background colors simultaneously with transparency options.
# Automatically copies the active escape sequence to the clipboard on selection changes.
# Prints the chosen escape sequence to stdout on exit (optionally formatted as a bash $'...' string).

import sys
import os
import tty
import termios
import select
import signal
import atexit
import re
import subprocess

# Global state
state = {
    'bold': False,
    'faint': False,
    'italics': False,
    'bash_string': True,  # Enabled by default
    'fg_color': 15,       # Default FG: White
    'fg_trans': False,    # FG transparency
    'bg_color': 0,        # Default BG: Black
    'bg_trans': True,     # BG transparency
    'last_copied': 'full', # Track which string is currently in the clipboard
    'text': '',           # User's typed preview text
    'editing_text': False, # True when typing in the text field
    'fg_rgb': [5, 5, 5],
    'bg_rgb': [0, 0, 0],
    'use_fg_rgb': False,
    'use_bg_rgb': False
}

click_map = {}
old_settings = None
terminal_setup = False

# Regex to strip ANSI escapes for calculating printable text width
ANSI_ESCAPE = re.compile(r'\x1b\[[0-9;]*[a-zA-Z]')

def printable_len(s):
    return len(ANSI_ESCAPE.sub('', s))

def ep(s):
    normalized = s.replace('\r\n', '\n').replace('\n', '\r\n')
    sys.stderr.write(normalized)

def eflush():
    sys.stderr.flush()

def setup_terminal():
    global terminal_setup, old_settings
    if terminal_setup:
        return
    try:
        old_settings = termios.tcgetattr(sys.stdin.fileno())
        tty.setraw(sys.stdin.fileno())
        # Enable alternate screen, SGR mouse reporting, and hide cursor
        ep("\x1b[?1049h\x1b[?1000h\x1b[?1006h\x1b[?25l")
        eflush()
        terminal_setup = True
    except Exception as e:
        sys.stderr.write(f"Error setting up terminal: {e}\n")
        sys.exit(1)

def restore_terminal():
    global terminal_setup
    if not terminal_setup:
        return
    if old_settings is not None:
        try:
            termios.tcsetattr(sys.stdin.fileno(), termios.TCSADRAIN, old_settings)
        except Exception:
            pass
    # Disable mouse tracking, switch to main screen, show cursor
    ep("\x1b[?1006l\x1b[?1000l\x1b[?1049l\x1b[?25h")
    eflush()
    terminal_setup = False

def signal_handler(signum, frame):
    restore_terminal()
    sys.exit(128 + signum)

# Register cleanup
atexit.register(restore_terminal)
signal.signal(signal.SIGINT, signal_handler)
signal.signal(signal.SIGTERM, signal_handler)

def copy_to_clipboard(text):
    try:
        subprocess.run(['xclip', '-silent', '-i', '-selection', 'clipboard'],
                       input=text.encode('utf-8'),
                       stdout=subprocess.DEVNULL,
                       stderr=subprocess.DEVNULL,
                       check=True)
    except Exception as e:
        ep(f"Error copying to clipboard: {e}\n")
        eflush()

def get_esc_seq():
    attrs = []
    if state['bold']:
        attrs.append("1")
    if state['faint']:
        attrs.append("2")
    if state['italics']:
        attrs.append("3")
        
    if not state['fg_trans']:
        if state['use_fg_rgb']:
            r, g, b = state['fg_rgb']
            fg_color = 16 + 36 * r + 6 * g + b
        else:
            fg_color = state['fg_color']
        attrs.append(f"38;5;{fg_color}")
        
    if not state['bg_trans']:
        if state['use_bg_rgb']:
            r, g, b = state['bg_rgb']
            bg_color = 16 + 36 * r + 6 * g + b
        else:
            bg_color = state['bg_color']
        attrs.append(f"48;5;{bg_color}")
        
    if not attrs:
        return "\\e[0m"
    else:
        return f"\\e[{';'.join(attrs)}m"

def get_output_string():
    esc_seq = get_esc_seq()
    if state['bash_string']:
        return f"$'{esc_seq}'"
    else:
        return esc_seq

def get_full_string():
    esc_seq = get_esc_seq()
    user_text = state['text']
    if state['bash_string']:
        return f"$'{esc_seq}{user_text}\\e[0m'"
    else:
        return f"{esc_seq}{user_text}\\e[0m"

def update_selection(fg=None, bg=None):
    if fg is not None:
        state['fg_color'] = fg
        state['fg_trans'] = False
    if bg is not None:
        state['bg_color'] = bg
        state['bg_trans'] = False
    state['last_copied'] = 'full'
    out_str = get_full_string()
    copy_to_clipboard(out_str)

def draw_screen():
    global click_map
    click_map = {}
    
    # Home cursor and clear screen down
    ep("\x1b[H\x1b[J")
    
    # Header (Row 1)
    ep(" \x1b[1m=== ANSI Color Picker ===\x1b[0m\n\n")
    
    # Row 3: Modifiers
    y = 3
    raw_line = "  Modifiers:  "
    ep(raw_line)
    
    def add_checkbox(label, key):
        nonlocal raw_line
        start_x = printable_len(raw_line) + 1
        checked = "x" if state[key] else " "
        
        style_start = ""
        style_end = ""
        if key == 'bold':
            style_start, style_end = "\x1b[1m", "\x1b[0m"
        elif key == 'faint':
            style_start, style_end = "\x1b[2m", "\x1b[0m"
        elif key == 'italics':
            style_start, style_end = "\x1b[3m", "\x1b[0m"
            
        cb_str = f"[{checked}] {style_start}{label}{style_end}"
        ep(cb_str)
        raw_line += cb_str
        end_x = printable_len(raw_line)
        
        for x in range(start_x, end_x + 1):
            click_map[(x, y)] = ('toggle', key)
            
    add_checkbox("[B]old", "bold")
    ep("    ")
    raw_line += "    "
    add_checkbox("[F]aint", "faint")
    ep("    ")
    raw_line += "    "
    add_checkbox("[I]talics", "italics")
    ep("\n\n")
    
    # Color grid rows drawing function
    def draw_color_row(colors, y_blocks, grid_type, use_gray_bg=False):
        global click_map
        indent = "    "
        ep(indent)
        
        current_x = printable_len(indent) + 1
        for c in colors:
            is_selected = (state['fg_color'] == c) if grid_type == 'fg' else (state['bg_color'] == c)
            
            if is_selected:
                if c < 10:
                    text = f" [{c}] "
                elif c < 100:
                    text = f" [{c}]"
                else:
                    text = f"[{c}]"
            else:
                if c < 10:
                    text = f"  {c}  "
                elif c < 100:
                    text = f"  {c} "
                else:
                    text = f" {c} "
                    
            if grid_type == 'fg':
                attrs = [f"38;5;{c}"]
                if use_gray_bg:
                    attrs.append("48;5;8")
            else:
                if c < 16:
                    fg = 15 if c in [0, 1, 4, 5, 8, 9, 12, 13] else 0
                else:
                    fg = 15 if c < 244 else 0
                attrs = [f"38;5;{fg}", f"48;5;{c}"]
                
            if state['bold']:
                attrs.append("1")
            if state['faint']:
                attrs.append("2")
            if state['italics']:
                attrs.append("3")
                
            attr_str = ";".join(attrs)
            block_disp = f"\x1b[{attr_str}m{text}\x1b[0m"
            ep(block_disp)
            
            block_width = len(text)
            for x in range(current_x, current_x + block_width):
                click_map[(x, y_blocks)] = (f'pick_{grid_type}', c)
                
            sep = " "
            ep(sep)
            current_x += block_width + len(sep)
            
        ep("\n")
        return y_blocks + 1

    def draw_rgb_picker(y_line, is_fg):
        nonlocal y_next
        rgb_key = 'fg_rgb' if is_fg else 'bg_rgb'
        use_key = 'use_fg_rgb' if is_fg else 'use_bg_rgb'
        r_val, g_val, b_val = state[rgb_key]
        
        prefix = "    RGB Value: "
        ep(prefix)
        current_x = printable_len(prefix) + 1
        
        # Draw R picker
        r_label = " \x1b[31mR:\x1b[0m"
        ep(r_label)
        current_x += printable_len(r_label)
        for val in range(6):
            is_sel = (r_val == val)
            disp = f"[{val}]" if is_sel else f" {val} "
            if is_sel and state[use_key]:
                ep(f"\x1b[1;32m{disp}\x1b[0m")
            else:
                ep(disp)
            for offset in range(len(disp)):
                click_map[(current_x + offset, y_line)] = ('set_rgb', (is_fg, 0, val))
            current_x += len(disp)
            
        # Draw G picker
        g_label = " \x1b[32mG:\x1b[0m"
        ep(g_label)
        current_x += printable_len(g_label)
        for val in range(6):
            is_sel = (g_val == val)
            disp = f"[{val}]" if is_sel else f" {val} "
            if is_sel and state[use_key]:
                ep(f"\x1b[1;32m{disp}\x1b[0m")
            else:
                ep(disp)
            for offset in range(len(disp)):
                click_map[(current_x + offset, y_line)] = ('set_rgb', (is_fg, 1, val))
            current_x += len(disp)
            
        # Draw B picker
        b_label = " \x1b[34mB:\x1b[0m"
        ep(b_label)
        current_x += printable_len(b_label)
        for val in range(6):
            is_sel = (b_val == val)
            disp = f"[{val}]" if is_sel else f" {val} "
            if is_sel and state[use_key]:
                ep(f"\x1b[1;32m{disp}\x1b[0m")
            else:
                ep(disp)
            for offset in range(len(disp)):
                click_map[(current_x + offset, y_line)] = ('set_rgb', (is_fg, 2, val))
            current_x += len(disp)
            
        ep("\n")
        y_next += 1

    # Row 5: Foreground Color Section
    y = 5
    raw_line = "  Foreground Color:  "
    ep(raw_line)
    
    start_x = printable_len(raw_line) + 1
    checked = "x" if state['fg_trans'] else " "
    cb_str = f"[{checked}] Default"
    ep(cb_str + "\n")
    raw_line += cb_str
    end_x = printable_len(raw_line)
    
    for x in range(start_x, end_x + 1):
        click_map[(x, y)] = ('toggle', 'fg_trans')
        
    y_next = draw_color_row(range(0, 8), 6, 'fg', use_gray_bg=True)
    y_next = draw_color_row(range(8, 16), y_next, 'fg', use_gray_bg=False)
    ep("\n")
    y_next += 1
    y_next = draw_color_row(range(232, 244), y_next, 'fg', use_gray_bg=True)
    y_next = draw_color_row(range(244, 256), y_next, 'fg', use_gray_bg=False)
    ep("\n")
    y_next += 1
    
    # Foreground RGB picker
    draw_rgb_picker(y_next, is_fg=True)
    ep("\n")
    y_next += 1
    
    # Row y_next: Background Color Section
    y = y_next
    raw_line = "  Background Color:  "
    ep(raw_line)
    
    start_x = printable_len(raw_line) + 1
    checked = "x" if state['bg_trans'] else " "
    cb_str = f"[{checked}] Default"
    ep(cb_str + "\n")
    raw_line += cb_str
    end_x = printable_len(raw_line)
    
    for x in range(start_x, end_x + 1):
        click_map[(x, y)] = ('toggle', 'bg_trans')
        
    y_next = draw_color_row(range(0, 8), y_next + 1, 'bg')
    y_next = draw_color_row(range(8, 16), y_next, 'bg')
    ep("\n")
    y_next += 1
    y_next = draw_color_row(range(232, 244), y_next, 'bg')
    y_next = draw_color_row(range(244, 256), y_next, 'bg')
    ep("\n")
    y_next += 1
    
    # Background RGB picker
    draw_rgb_picker(y_next, is_fg=False)
    ep("\n")
    y_next += 1
    
    # Text Field Section
    y_text = y_next
    text_label = "  Text (click or press 't' to edit): "
    text_val = state['text']
    if state['editing_text']:
        display_val = f"\x1b[4m{text_val}\x1b[0m\x1b[7m \x1b[0m"
    else:
        if text_val:
            display_val = f"\x1b[4m{text_val}\x1b[0m"
        else:
            display_val = "\x1b[2m<click or press 't' to type preview text>\x1b[0m"
            
    ep(f"{text_label}{display_val}\n\n")
    val_len = len(text_val) if text_val else len("<click or press 't' to type preview text>")
    for x in range(1, len(text_label) + val_len + 1):
        click_map[(x, y_text)] = ('edit_text', None)
    y_next += 2

    # Preview Section
    y_preview = y_next
    ep("  Preview:\n")
    y_next += 1
    
    preview_indent = "    "
    ep(preview_indent)
    
    attrs = []
    if state['bold']:
        attrs.append("1")
    if state['faint']:
        attrs.append("2")
    if state['italics']:
        attrs.append("3")
        
    if not state['fg_trans']:
        if state['use_fg_rgb']:
            r, g, b = state['fg_rgb']
            fg_color = 16 + 36 * r + 6 * g + b
        else:
            fg_color = state['fg_color']
        attrs.append(f"38;5;{fg_color}")
        
    if not state['bg_trans']:
        if state['use_bg_rgb']:
            r, g, b = state['bg_rgb']
            bg_color = 16 + 36 * r + 6 * g + b
        else:
            bg_color = state['bg_color']
        attrs.append(f"48;5;{bg_color}")
        
    attr_str = ";".join(attrs)
    preview_text = state['text'] if state['text'] else "  AaBbCcDdEeFfGg 0123456789  "
    if not attr_str:
        ep(f"{preview_text}\n\n")
    else:
        ep(f"\x1b[{attr_str}m{preview_text}\x1b[0m\n\n")
    y_next += 2
    
    # Checkbox for formatting output string
    y = y_next
    raw_line = "  "
    ep(raw_line)
    add_checkbox("Ba[s]h string", "bash_string")
    ep("\n\n")
    y_next += 2
    
    # Output string representation
    y_active = y_next
    active_label = "  Sequence:     "
    active_val = get_output_string()
    ep(f"{active_label}\x1b[1m{active_val}\x1b[0m\n")
    for x in range(1, len(active_label) + len(active_val) + 1):
        click_map[(x, y_active)] = ('copy_active', None)
    y_next += 1
    
    if state['last_copied'] == 'active':
        ep("                \x1b[2m(Copied to clipboard)\x1b[0m\n")
    else:
        ep("\n")
    y_next += 1
    
    # Reset string representation
    y_reset = y_next
    reset_label = "  Reset string: "
    if state['bash_string']:
        reset_val = "$'\\e[0m'"
    else:
        reset_val = "\\e[0m"
    ep(f"{reset_label}\x1b[1m{reset_val}\x1b[0m\n")
    for x in range(1, len(reset_label) + len(reset_val) + 1):
        click_map[(x, y_reset)] = ('copy_reset', None)
    y_next += 1
    
    if state['last_copied'] == 'reset':
        ep("                \x1b[2m(Copied to clipboard)\x1b[0m\n")
    else:
        ep("\n")
    y_next += 1

    # Full string representation
    y_full = y_next
    full_label = "  Full string:  "
    full_val = get_full_string()
    ep(f"{full_label}\x1b[1m{full_val}\x1b[0m\n")
    for x in range(1, len(full_label) + len(full_val) + 1):
        click_map[(x, y_full)] = ('copy_full', None)
    y_next += 1
    
    if state['last_copied'] == 'full':
        ep("                \x1b[2m(Copied to clipboard)\x1b[0m\n\n")
    else:
        ep("\n\n")
    y_next += 2
    
    # Buttons
    y_exit = y_next
    buttons_line = "  "
    ep(buttons_line)
    
    start_x_select = printable_len(buttons_line) + 1
    select_text = "[ Select & Close ]"
    select_disp = f"\x1b[1;32m{select_text}\x1b[0m"
    ep(select_disp)
    buttons_line += select_text
    end_x_select = printable_len(buttons_line)
    
    for x in range(start_x_select, end_x_select + 1):
        click_map[(x, y_exit)] = ('confirm', None)
        
    spacer = "    "
    ep(spacer)
    buttons_line += spacer
    
    start_x_cancel = printable_len(buttons_line) + 1
    cancel_text = "[ Cancel / Exit ]"
    cancel_disp = f"\x1b[31m{cancel_text}\x1b[0m"
    ep(cancel_disp + "\n")
    buttons_line += cancel_text
    end_x_cancel = printable_len(buttons_line)
    
    for x in range(start_x_cancel, end_x_cancel + 1):
        click_map[(x, y_exit)] = ('exit', None)
        
    eflush()

def read_key():
    r, _, _ = select.select([sys.stdin], [], [], 0.1)
    if not r:
        return None
    try:
        b = os.read(sys.stdin.fileno(), 1)
    except Exception:
        return None
    if not b:
        return None
        
    if b == b'\x03': # Ctrl-C
        return 'ctrl-c'
        
    if b == b'\x1b':
        r, _, _ = select.select([sys.stdin], [], [], 0.05)
        if not r:
            return 'escape'
        try:
            b2 = os.read(sys.stdin.fileno(), 1)
        except Exception:
            return 'escape'
        if b2 == b'[':
            seq = b""
            while True:
                try:
                    ch_b = os.read(sys.stdin.fileno(), 1)
                except Exception:
                    break
                if not ch_b:
                    break
                seq += ch_b
                if 0x40 <= ch_b[0] <= 0x7E:
                    break
            seq_str = seq.decode('utf-8', errors='ignore')
            if seq_str.startswith('<'):
                try:
                    parts = seq_str[1:-1].split(';')
                    pb = int(parts[0])
                    px = int(parts[1])
                    py = int(parts[2])
                    is_press = seq_str[-1] == 'M'
                    return ('mouse', pb, px, py, is_press)
                except Exception:
                    pass
            return ('esc_seq', '[' + seq_str)
        else:
            return ('esc_seq', b2.decode('utf-8', errors='ignore'))
            
    return b.decode('utf-8', errors='ignore')

def select_color_and_exit():
    if state['last_copied'] == 'full':
        result = get_full_string()
    elif state['last_copied'] == 'reset':
        result = "$'\\e[0m'" if state['bash_string'] else "\\e[0m"
    else:
        result = get_output_string()
    restore_terminal()
    sys.stdout.write(result + "\n")
    sys.stdout.flush()
    sys.exit(0)

def main():
    setup_terminal()
    update_selection()  # Set initial clipboard string
    draw_screen()
    
    while True:
        key = read_key()
        if key is None:
            continue
            
        if state['editing_text']:
            if key == 'ctrl-c':
                break
            elif key in ['escape', '\x1b']:
                state['editing_text'] = False
                draw_screen()
                continue
            elif key in ['\r', '\n']:
                state['editing_text'] = False
                draw_screen()
                continue
            elif key in ['\x7f', '\x08']:
                if state['text']:
                    state['text'] = state['text'][:-1]
                    if state['last_copied'] == 'full':
                        copy_to_clipboard(get_full_string())
                    draw_screen()
                continue
            elif isinstance(key, str) and len(key) == 1 and ord(key) >= 32:
                state['text'] += key
                if state['last_copied'] == 'full':
                    copy_to_clipboard(get_full_string())
                draw_screen()
                continue
            elif isinstance(key, tuple) and key[0] == 'mouse':
                _, pb, px, py, is_press = key
                if pb == 0 and not is_press:
                    action = click_map.get((px, py))
                    if action:
                        act_type, val = action
                        if act_type != 'edit_text':
                            state['editing_text'] = False
                            # Fall through to process mouse click below
                        else:
                            continue
                    else:
                        state['editing_text'] = False
                        draw_screen()
                        continue
            else:
                continue

        if key in ['ctrl-c', 'q', 'escape', '\x1b']:
            break
            
        if key in ['\r', '\n']:
            select_color_and_exit()
            
        if key in ['b', 'B']:
            state['bold'] = not state['bold']
            update_selection()
            draw_screen()
        elif key in ['s', 'S']:
            state['bash_string'] = not state['bash_string']
            update_selection()
            draw_screen()
        elif key in ['i', 'I']:
            state['italics'] = not state['italics']
            update_selection()
            draw_screen()
        elif key in ['f', 'F']:
            state['faint'] = not state['faint']
            update_selection()
            draw_screen()
        elif key in ['t', 'T']:
            state['editing_text'] = True
            draw_screen()
            
        if isinstance(key, tuple) and key[0] == 'mouse':
            _, pb, px, py, is_press = key
            if pb == 0 and not is_press:
                action = click_map.get((px, py))
                if action:
                    act_type, val = action
                    if act_type == 'toggle':
                        if val == 'fg_trans':
                            state['fg_trans'] = not state['fg_trans']
                            if state['fg_trans']:
                                state['use_fg_rgb'] = False
                        elif val == 'bg_trans':
                            state['bg_trans'] = not state['bg_trans']
                            if state['bg_trans']:
                                state['use_bg_rgb'] = False
                        else:
                            state[val] = not state[val]
                        update_selection()
                        draw_screen()
                    elif act_type == 'pick_fg':
                        state['use_fg_rgb'] = False
                        update_selection(fg=val)
                        draw_screen()
                    elif act_type == 'pick_bg':
                        state['use_bg_rgb'] = False
                        update_selection(bg=val)
                        draw_screen()
                    elif act_type == 'set_rgb':
                        is_fg, comp_idx, value_val = val
                        if is_fg:
                            state['fg_rgb'][comp_idx] = value_val
                            state['use_fg_rgb'] = True
                            state['fg_trans'] = False
                        else:
                            state['bg_rgb'][comp_idx] = value_val
                            state['use_bg_rgb'] = True
                            state['bg_trans'] = False
                        update_selection()
                        draw_screen()
                    elif act_type == 'confirm':
                        select_color_and_exit()
                    elif act_type == 'copy_active':
                        copy_to_clipboard(get_output_string())
                        state['last_copied'] = 'active'
                        draw_screen()
                    elif act_type == 'copy_reset':
                        reset_str = "$'\\e[0m'" if state['bash_string'] else "\\e[0m"
                        copy_to_clipboard(reset_str)
                        state['last_copied'] = 'reset'
                        draw_screen()
                    elif act_type == 'copy_full':
                        copy_to_clipboard(get_full_string())
                        state['last_copied'] = 'full'
                        draw_screen()
                    elif act_type == 'edit_text':
                        state['editing_text'] = True
                        draw_screen()
                    elif act_type == 'exit':
                        break
                        
    restore_terminal()
    sys.exit(0)

