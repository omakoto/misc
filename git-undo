#!/usr/bin/env python3
# -*- coding: utf-8 -*-
#
# git-undo: Show locally changed files and undo them to the latest remote commit.
# Run git-undo_test.bash to test changes.
#
# This script displays a list of locally changed files (both uncommitted and committed
# locally since the latest remote commit) using fzf, allowing the user to select
# files to revert to their state at the remote commit. It creates a backup tag
# with a timestamp before performing the rollback.

import sys
import os
import subprocess
import datetime
import shutil
from typing import List, Set

def print_error(msg: str) -> None:
    # Use bold-yellow and beep
    sys.stderr.write(f"\a\033[1;33m{msg}\033[m\n")
    sys.stderr.flush()

def print_help() -> None:
    sys.stdout.write("""git-undo - Show locally changed files and undo them to the latest remote commit.

Usage:
  git-undo [options]

Before performing any rollback, a backup tag named 'undo-tag-[yyyy-mm-dd-hh-mm-ss.sss]'
will be created so that the changes can be restored if needed.

Options:
  -h, --help    Show this help message and exit.

Examples:
  # Interactively select files to undo:
  git-undo
""")
    sys.stdout.flush()

def resolve_remote_commit() -> str:
    # Try upstream tracking branch first
    res = subprocess.run(["git", "rev-parse", "--verify", "@{u}"], capture_output=True, text=True)
    if res.returncode == 0:
        return res.stdout.strip()

    # Try common default remote branches
    for ref in ["origin/master", "origin/main", "origin/trunk"]:
        res = subprocess.run(["git", "rev-parse", "--verify", ref], capture_output=True, text=True)
        if res.returncode == 0:
            return res.stdout.strip()

    # Try any remote branch
    res = subprocess.run(["git", "branch", "-r"], capture_output=True, text=True)
    if res.returncode == 0:
        branches = [b.strip() for b in res.stdout.splitlines() if b.strip() and "->" not in b]
        if branches:
            res2 = subprocess.run(["git", "rev-parse", "--verify", branches[0]], capture_output=True, text=True)
            if res2.returncode == 0:
                return res2.stdout.strip()

    raise Exception("Could not find any remote tracking branch or remote commit.")

def get_locally_changed_files(remote_commit: str) -> List[str]:
    # Run git diff --name-only remote_commit
    diff_res = subprocess.run(
        ["git", "diff", "--name-only", remote_commit],
        capture_output=True, text=True, check=True
    )
    diff_files = [f for f in diff_res.stdout.splitlines() if f.strip()]

    # Run git ls-files --others --exclude-standard
    untracked_res = subprocess.run(
        ["git", "ls-files", "--others", "--exclude-standard"],
        capture_output=True, text=True, check=True
    )
    untracked_files = [f for f in untracked_res.stdout.splitlines() if f.strip()]

    # Combine and remove duplicates while preserving order
    seen: Set[str] = set()
    combined: List[str] = []
    for f in diff_files + untracked_files:
        if f not in seen:
            seen.add(f)
            combined.append(f)
    return combined

def main() -> None:
    if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help"):
        print_help()
        sys.exit(0)

    # Ensure we are inside a git repository
    res_toplevel = subprocess.run(["git", "rev-parse", "--show-toplevel"], capture_output=True, text=True)
    if res_toplevel.returncode != 0:
        print_error("Error: Not a git repository")
        sys.exit(1)
    toplevel = res_toplevel.stdout.strip()

    # Change to toplevel to make paths relative to it
    os.chdir(toplevel)

    try:
        remote_commit = resolve_remote_commit()
    except Exception as e:
        print_error(f"Error: {e}")
        sys.exit(1)

    files = get_locally_changed_files(remote_commit)
    if not files:
        sys.stdout.write("No locally changed files compared to remote.\n")
        sys.stdout.flush()
        sys.exit(0)

    # Run FZF to let the user select which files to undo
    fzf_input = "\n".join(files)
    fzf_proc = subprocess.run(
        ["fzf", "--multi", "--prompt=Select files to undo: "],
        input=fzf_input,
        capture_output=True,
        text=True
    )
    if fzf_proc.returncode != 0:
        # User cancelled fzf
        sys.exit(0)

    selected_files = [f for f in fzf_proc.stdout.splitlines() if f.strip()]
    if not selected_files:
        sys.exit(0)

    # Generate tag name with milliseconds: undo-tag-yyyy-mm-dd-hh-mm-ss.sss
    now = datetime.datetime.now()
    timestamp = now.strftime("%Y-%m-%d-%H-%M-%S.%f")[:-3]
    tag_name = f"undo-tag-{timestamp}"

    # Create backup tag
    sys.stdout.write(f"Creating backup tag: {tag_name}\n")
    sys.stdout.flush()

    try:
        # Get list of untracked files before staging them
        untracked_res = subprocess.run(
            ["git", "ls-files", "--others", "--exclude-standard"],
            capture_output=True, text=True, check=True
        )
        untracked_files = [f for f in untracked_res.stdout.splitlines() if f.strip()]

        # 1. Save current index tree
        write_res = subprocess.run(["git", "write-tree"], capture_output=True, text=True, check=True)
        saved_index_tree = write_res.stdout.strip()

        # 2. Stage all changes (tracked and untracked)
        subprocess.run(["git", "add", "-A"], check=True)

        # 3. Write tree of the backup state
        write_res2 = subprocess.run(["git", "write-tree"], capture_output=True, text=True, check=True)
        backup_tree = write_res2.stdout.strip()

        # 4. Create backup commit
        commit_res = subprocess.run(
            ["git", "commit-tree", backup_tree, "-p", "HEAD", "-m", f"git-undo backup: {tag_name}"],
            capture_output=True, text=True, check=True
        )
        backup_commit = commit_res.stdout.strip()

        # 5. Tag the backup commit
        subprocess.run(["git", "tag", tag_name, backup_commit], check=True)

        # 6. Restore the index to the saved state
        subprocess.run(["git", "read-tree", saved_index_tree], check=True)

        # 7. Unstage the untracked files
        if untracked_files:
            subprocess.run(["git", "reset", "HEAD", "--"] + untracked_files, capture_output=True)
    except Exception as e:
        print_error(f"Warning: Failed to create backup tag using commit-tree: {e}")
        # Fallback: Tag HEAD
        subprocess.run(["git", "tag", tag_name, "HEAD"], check=True)

    # Roll back the selected files
    files_to_checkout: List[str] = []
    files_to_delete: List[str] = []

    for f in selected_files:
        # Check if file exists in remote_commit
        cat_res = subprocess.run(["git", "cat-file", "-e", f"{remote_commit}:{f}"], capture_output=True)
        if cat_res.returncode == 0:
            files_to_checkout.append(f)
        else:
            files_to_delete.append(f)

    if files_to_checkout:
        subprocess.run(["git", "checkout", remote_commit, "--"] + files_to_checkout, check=True)

    for f in files_to_delete:
        abs_path = os.path.join(toplevel, f)
        if os.path.exists(abs_path):
            if os.path.isdir(abs_path) and not os.path.islink(abs_path):
                shutil.rmtree(abs_path)
            else:
                os.remove(abs_path)

    sys.stdout.write("Rollback completed successfully.\n")
    sys.stdout.flush()

if __name__ == "__main__":
    main()
